---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import gazaVideo from "../assets/img/v-gaza.web.mp4";
import gazaPoster from "../assets/img/v-gaza-poster.jpg";
import d1handImg from "../assets/img/d1hand.avif";

const gazaReelUrl = "https://www.instagram.com/reel/DRMmx_ODFXL/?igsh=MTEwdzV6d3Frc3F5ZQ==";

const allJewelry  = await getCollection("jewelry");
const allKnitting = await getCollection("knitting");

const decoImports = import.meta.glob<{ default: ImageMetadata }>(
  "../content/decorative/*.{jpg,jpeg,webp,avif,png}",
  { eager: true }
);
const allDeco = Object.values(decoImports).map((m) => m.default);
const decoSrcs = JSON.stringify(allDeco.map((img) => img.src));

const byDate = (a: { data: { date: string } }, b: { data: { date: string } }) =>
  b.data.date.localeCompare(a.data.date);

const jewelry  = allJewelry.sort(byDate);
const knitting = allKnitting.sort(byDate);


type ProductEntry = typeof jewelry[0] | typeof knitting[0];
type GridItem =
  | { kind: "jewelry" | "knitting"; entry: ProductEntry; img?: undefined; span?: number }
  | { kind: "decorative"; entry?: undefined; img: ImageMetadata; span?: number }
  | { kind: "empty"; entry?: undefined; img?: undefined; span?: number };

const J = (i: number, span = 1): GridItem => ({ kind: "jewelry",    entry: jewelry[i],  span });
const K = (i: number, span = 1): GridItem => ({ kind: "knitting",   entry: knitting[i], span });
const D = (i: number, span = 1): GridItem => ({ kind: "decorative", img:   allDeco[i],  span });

const gridA: GridItem[] = [
  // Row 1
  J(0), D(0), K(0),
  // Row 2
  D(1), K(1), J(1),
];

const gridB: GridItem[] = [
  // Row 3
  D(2), J(2), K(2),
  // Row 4
  J(3), D(3), J(4),
];

const gridC: GridItem[] = [
  // Row 5
  D(4), J(5), D(5),
];

// 3-column grid slots — fixed pattern, rows always sum to 3
const slots: { span: number; nudge: string }[] = [
  { span: 1, nudge: "0px"  },
  { span: 1, nudge: "28px" },
  { span: 1, nudge: "12px" },
  { span: 2, nudge: "0px"  },
  { span: 1, nudge: "36px" },
  { span: 1, nudge: "20px" },
  { span: 1, nudge: "8px"  },
  { span: 1, nudge: "32px" },
  { span: 1, nudge: "16px" },
  { span: 1, nudge: "0px"  },
  { span: 2, nudge: "16px" },
  { span: 1, nudge: "44px" },
  { span: 1, nudge: "8px"  },
];

// Asymmetric image padding (top right bottom left)
const borderPaddings: string[] = [
  "0 0 12% 0",
  "0 14% 0 0",
  "13% 0 0 0",
  "0 0 0 14%",
  "0 10% 12% 0",
  "11% 0 0 10%",
  "0 0 13% 11%",
  "10% 12% 0 0",
  "13% 0 11% 0",
  "0 11% 0 13%",
];

const insets: [number, number, number, number][] = [
  [3.5, 2.8, 4.2, 3.1],
  [4.1, 2.6, 3.0, 4.4],
  [3.8, 3.2, 2.7, 3.5],
  [2.4, 4.0, 3.7, 2.8],
  [3.0, 3.5, 4.3, 2.6],
  [4.5, 2.9, 3.2, 3.8],
  [2.6, 3.7, 4.0, 2.9],
  [3.6, 2.7, 3.3, 4.2],
  [4.0, 3.1, 2.5, 3.9],
];

const cornerOffsets: [number,number,number,number,number,number,number,number][] = [
  [ 0.3, 0.2,-0.2, 0.4, 0.1,-0.3,-0.4, 0.1],
  [-0.2, 0.3, 0.4,-0.1,-0.3, 0.2, 0.2,-0.4],
  [ 0.1,-0.4, 0.3, 0.2,-0.2, 0.4,-0.3,-0.1],
  [-0.3, 0.1,-0.1, 0.4, 0.4,-0.2, 0.2, 0.3],
  [ 0.4,-0.2, 0.1, 0.3,-0.4, 0.1, 0.3,-0.3],
  [-0.1, 0.4,-0.3,-0.2, 0.2, 0.3,-0.4, 0.1],
  [ 0.2, 0.3, 0.4,-0.3,-0.1, 0.2, 0.3,-0.4],
  [-0.4, 0.1, 0.2, 0.4, 0.3,-0.1,-0.2, 0.3],
  [ 0.3,-0.3,-0.2, 0.1, 0.4, 0.2,-0.1,-0.4],
];


const textOffsets: { bottom: string; left?: string; right?: string; textAlign?: string }[] = [
  { bottom: "-2.4em",  left: "0"                             },
  { bottom: "-4.8em",  left: "0"                             },
  { bottom: "-2.8em",  right: "0",      textAlign: "right"   },
  { bottom: "-2.0em",  left: "30%"                           },
  { bottom: "-4.0em",  left: "0"                             },
  { bottom: "-5.6em",  right: "0",      textAlign: "right"   },
  { bottom: "-1.6em",  left: "60%"                           },
  { bottom: "-3.2em",  left: "0"                             },
  { bottom: "-4.8em",  right: "0",      textAlign: "right"   },
  { bottom: "-3.2em",  right: "20%",    textAlign: "right"   },
];

const fmt = new Intl.NumberFormat("sv-SE").format;

function overlayStyle(idx: number): string {
  const o = textOffsets[idx % textOffsets.length];
  const parts = [`bottom:${o.bottom}`];
  if (o.left  !== undefined) parts.push(`left:${o.left}`);
  if (o.right !== undefined) parts.push(`right:${o.right}`);
  if (o.textAlign)           parts.push(`text-align:${o.textAlign}`);
  return parts.join(";");
}

function makeClip(
  [top, right, bottom, left]: [number, number, number, number],
  [o0, o1, o2, o3, o4, o5, o6, o7]: [number,number,number,number,number,number,number,number]
): string {
  const t = top, r = 100 - right, b = 100 - bottom, l = left;
  return [
    `${l + o0}% ${t + o1}%`,
    `${r + o2}% ${t + o3}%`,
    `${r + o4}% ${b + o5}%`,
    `${l + o6}% ${b + o7}%`,
  ].join(", ");
}

function makeClipHover(
  [top, right, bottom, left]: [number, number, number, number],
  [o0, o1, o2, o3, o4, o5, o6, o7]: [number,number,number,number,number,number,number,number]
): string {
  // Expand outward: reduce insets by ~65%
  const f = 0.35;
  const t = top * f, r = 100 - right * f, b = 100 - bottom * f, l = left * f;
  return [
    `${l + o0 * f}% ${t + o1 * f}%`,
    `${r + o2 * f}% ${t + o3 * f}%`,
    `${r + o4 * f}% ${b + o5 * f}%`,
    `${l + o6 * f}% ${b + o7 * f}%`,
  ].join(", ");
}
---

<BaseLayout description="to.w — handmade jewelry and objects.">
  <div class="page-flow">

    <section class="collage" aria-label="Works — part 1">
      {gridA.map((item, i) => {
        const slot          = slots[i % slots.length];
        const inset         = insets[i % insets.length];
        const offsets       = cornerOffsets[i % cornerOffsets.length];
        const clipRest      = `polygon(${makeClip(inset, offsets)})`;
        const clipHover     = `polygon(${makeClipHover(inset, offsets)})`;
        const borderPadding = borderPaddings[i % borderPaddings.length];
        const itemStyle     = `grid-column: span ${item.span}; margin-top: ${slot.nudge};`;
        const imgStyle      = `--clip-rest:${clipRest};--clip-hover:${clipHover};clip-path:var(--clip-rest);`;
        if (item.kind === "empty") return <div style={itemStyle} aria-hidden="true" />;
        if (item.kind === "decorative") return (
          <div class="collage__deco" style={itemStyle} data-deco-imgs={decoSrcs}>
            <div class="collage__item-img collage__item-img--deco" style={imgStyle}>
              <img src={item.img.src} alt="" width={600} height={900} loading="lazy" style={`padding: ${borderPadding};`} />
            </div>
          </div>
        );
        const { entry, kind } = item;
        const href = kind === "jewelry" ? `/smycken/${entry.id}` : `/stickning/${entry.id}`;
        return (
          <a class:list={["collage__item", `collage__item--${kind}`]} href={href} style={itemStyle} aria-label={`View ${entry.data.title}`}>
            <div class="collage__item-img collage__item-img--bordered" style={imgStyle}>
              <Image src={entry.data.images[0]} alt={entry.data.title} loading="lazy" width={600} height={600} style={`padding: ${borderPadding};`} />
            </div>
            <div class="collage__item-overlay" style={overlayStyle(i)} aria-hidden="true">
              <span class="collage__item-title">{entry.data.title}</span>
              {entry.data.material && <span class="collage__item-meta">{entry.data.material}</span>}
              <span class="collage__item-meta">{fmt(entry.data.price)} kr</span>
            </div>
          </a>
        );
      })}
    </section>


    <section class="collage" aria-label="Works — part 2">
      {gridB.map((item, i) => {
        const si            = i + gridA.length;
        const slot          = slots[si % slots.length];
        const inset         = insets[si % insets.length];
        const offsets       = cornerOffsets[si % cornerOffsets.length];
        const clipRest      = `polygon(${makeClip(inset, offsets)})`;
        const clipHover     = `polygon(${makeClipHover(inset, offsets)})`;
        const borderPadding = borderPaddings[si % borderPaddings.length];
        const itemStyle     = `grid-column: span ${item.span}; margin-top: ${slot.nudge};`;
        const imgStyle      = `--clip-rest:${clipRest};--clip-hover:${clipHover};clip-path:var(--clip-rest);`;
        if (item.kind === "empty") return <div style={itemStyle} aria-hidden="true" />;
        if (item.kind === "decorative") return (
          <div class="collage__deco" style={itemStyle} data-deco-imgs={decoSrcs}>
            <div class="collage__item-img collage__item-img--deco" style={imgStyle}>
              <img src={item.img.src} alt="" width={600} height={900} loading="lazy" style={`padding: ${borderPadding};`} />
            </div>
          </div>
        );
        const { entry, kind } = item;
        const href = kind === "jewelry" ? `/smycken/${entry.id}` : `/stickning/${entry.id}`;
        return (
          <a class:list={["collage__item", `collage__item--${kind}`]} href={href} style={itemStyle} aria-label={`View ${entry.data.title}`}>
            <div class="collage__item-img collage__item-img--bordered" style={imgStyle}>
              <Image src={entry.data.images[0]} alt={entry.data.title} loading="lazy" width={600} height={600} style={`padding: ${borderPadding};`} />
            </div>
            <div class="collage__item-overlay" style={overlayStyle(si)} aria-hidden="true">
              <span class="collage__item-title">{entry.data.title}</span>
              {entry.data.material && <span class="collage__item-meta">{entry.data.material}</span>}
              <span class="collage__item-meta">{fmt(entry.data.price)} kr</span>
            </div>
          </a>
        );
      })}
    </section>

    <!-- Endeavours -->
    {(() => {
      const e0inset   = insets[0];
      const e0offsets = cornerOffsets[0];
      const e1inset   = insets[3];
      const e1offsets = cornerOffsets[3];
      const e0clip    = `polygon(${makeClip(e0inset, e0offsets)})`;
      const e1clip    = `polygon(${makeClip(e1inset, e1offsets)})`;
      return (
        <section class="endeavours" aria-label="Endeavours">
            <div class="endeavour">
            <div class="collage__item-img collage__item-img--bordered gaza-media" style={`clip-path:${e0clip};`}>
              <Image class="gaza-media__poster" src={gazaPoster} alt="Gaza-halsbandet" loading="lazy" width={600} height={750} />
              <button class="gaza-media__play" type="button" aria-label="Spela Gaza-video"></button>
              <video
                class="gaza-media__video"
                data-src={gazaVideo}
                poster={gazaPoster.src}
                aria-label="Gaza-halsbandet"
                muted
                playsinline
                controls
                preload="metadata"
              ></video>
            </div>
            <div class="endeavour__text">
              <p class="collage__item-title">Victor & Gaza</p>
              <p class="endeavour__body">Ett halsband graverat på återvunnet sterling silver, skapat i samarbete med <a class="endeavour__inline-link" href="https://www.instagram.com/vtelegin" target="_blank" rel="noopener noreferrer">Viktor Telegin</a>. 20 exemplar — alla intäkter gick till Rädda Barnen och deras arbete för barn i Gaza. <a class="endeavour__reel" href={gazaReelUrl} target="_blank" rel="noopener noreferrer">Se reel</a></p>
            </div>
          </div>
          <div class="endeavour endeavour--reversed">
            <div class="endeavour__text">
              <p class="collage__item-title">Typ Ett</p>
              <p class="endeavour__body">En tunn ring med en knut högst upp, designad exklusivt för <a class="endeavour__inline-link" href="https://webbshop.barndiabetesfonden.se/produkter/knut-ring-silver" target="_blank" rel="noopener noreferrer">Barndiabetesfonden</a>. Alla intäkter går till forskning om typ 1 diabetes — ett projekt som ligger mig varmt om hjärtat som förälder till ett barn med diabetes.</p>
            </div>
            <div class="collage__item-img collage__item-img--bordered" style={`clip-path:${e1clip};`}>
              <Image src={d1handImg} alt="D1-ringen" loading="lazy" width={600} height={750} />
            </div>
          </div>
        </section>
      );
    })()}

    <section class="collage collage--final" aria-label="Works — part 3">
      {gridC.map((item, i) => {
        const si            = i + gridA.length + gridB.length;
        const slot          = slots[si % slots.length];
        const inset         = insets[si % insets.length];
        const offsets       = cornerOffsets[si % cornerOffsets.length];
        const clipRest      = `polygon(${makeClip(inset, offsets)})`;
        const clipHover     = `polygon(${makeClipHover(inset, offsets)})`;
        const borderPadding = borderPaddings[si % borderPaddings.length];
        const itemStyle     = `grid-column: span ${item.span}; margin-top: ${slot.nudge};`;
        const imgStyle      = `--clip-rest:${clipRest};--clip-hover:${clipHover};clip-path:var(--clip-rest);`;
        if (item.kind === "empty") return <div style={itemStyle} aria-hidden="true" />;
        if (item.kind === "decorative") return (
          <div class="collage__deco" style={itemStyle} data-deco-imgs={decoSrcs}>
            <div class="collage__item-img collage__item-img--deco" style={imgStyle}>
              <img src={item.img.src} alt="" width={600} height={900} loading="lazy" style={`padding: ${borderPadding};`} />
            </div>
          </div>
        );
        const { entry, kind } = item;
        const href = kind === "jewelry" ? `/smycken/${entry.id}` : `/stickning/${entry.id}`;
        return (
          <a class:list={["collage__item", `collage__item--${kind}`]} href={href} style={itemStyle} aria-label={`View ${entry.data.title}`}>
            <div class="collage__item-img collage__item-img--bordered" style={imgStyle}>
              <Image src={entry.data.images[0]} alt={entry.data.title} loading="lazy" width={600} height={600} style={`padding: ${borderPadding};`} />
            </div>
            <div class="collage__item-overlay" style={overlayStyle(si)} aria-hidden="true">
              <span class="collage__item-title">{entry.data.title}</span>
              {entry.data.material && <span class="collage__item-meta">{entry.data.material}</span>}
              <span class="collage__item-meta">{fmt(entry.data.price)} kr</span>
            </div>
          </a>
        );
      })}
    </section>

  </div>
</BaseLayout>

<style>
  /* ── Page wrapper ── */
  .page-flow {
    display: flex;
    flex-direction: column;
    gap: var(--space-5xl);
  }

  /* ── Collage grid ── */
  .collage {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: var(--grid-gutter);
    row-gap: var(--space-5xl);
    padding: 0 var(--layout-gutter);
    max-width: var(--layout-site-width);
    margin: 0 auto;
    align-items: start;
    width: 100%;
    box-sizing: border-box;
  }

  /* ── Shared interlude shell ── */
  .interlude {
    width: 100%;
    max-width: var(--layout-site-width);
    margin: 0 auto;
    padding: 0 var(--layout-gutter);
    box-sizing: border-box;
  }

  .interlude__eyebrow {
    font-size: var(--font-size-sm);
    letter-spacing: var(--font-tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  .interlude__body {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--font-leading-relaxed);
    max-width: 44ch;
  }


  /* ── About interlude ── */
  .interlude--about {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: var(--space-4);
    max-height: 80vh;
  }

  .about__photo-wrap {
    grid-column: 4 / 7;
    grid-row: 1 / 4;
    position: relative;
    z-index: 0;
  }

  .about__photo-wrap::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, var(--color-bg-base) 0%, transparent 60%);
  }

  .about__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about__headline {
    grid-column: 2 / 6;
    grid-row: 2 / 3;
    font-family: var(--font-body);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-light);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--color-accent);
    margin: 0;
    align-self: start;
    position: relative;
    z-index: 1;
  }

  .about__body {
    grid-column: 2 / 6;
    grid-row: 3 / 4;
    font-size: var(--font-size-base);
    color: var(--color-text-primary);
    position: relative;
    z-index: 1;
    line-height: var(--font-leading-snug);
    max-width: none;
  }

  /* ── Endeavours ── */
  .endeavours {
    display: flex;
    flex-direction: column;
    gap: var(--space-48);
    max-width: var(--layout-site-width);
    margin: 0 auto;
    padding: 0 var(--layout-gutter);
    box-sizing: border-box;
  }

  .endeavour {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: var(--space-10);
    align-items: center;
  }

  .endeavour .collage__item-img {
    aspect-ratio: 4 / 5;
    width: 100%;
    filter: contrast(1.08) saturate(0.7);
  }

  .endeavour .collage__item-img::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, var(--dusty-rose-light) 0%, transparent 60%);
    mix-blend-mode: multiply;
    pointer-events: none;
    z-index: 2;
  }

  .endeavour__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .endeavour--reversed {
    grid-template-columns: 1fr 300px;
  }

  .endeavour--reversed .collage__item-img {
    order: 1;
  }

  .endeavour__text .collage__item-title {
    font-family: var(--brand-font-curious);
  }

  .endeavour__body {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--font-leading-relaxed);
    margin-top: 0;
    max-width: 44ch;
  }

  .endeavour__inline-link {
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Responsive ── */
  @media (max-width: 760px) {
    .page-flow {
      gap: var(--space-24);
    }

    .collage {
      grid-template-columns: repeat(2, 1fr);
      row-gap: var(--space-32);
    }

    .collage__deco {
      display: none;
    }

    .collage--final {
      display: none;
    }

    .endeavours {
      gap: var(--space-32);
      padding: var(--space-16) var(--layout-gutter);
    }

    .interlude--about { grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; max-height: none; }
    .about__photo-wrap { grid-column: 2; grid-row: 1 / 3; }
    .about__photo { width: 100%; height: auto; }
    .about__headline { grid-column: 1 / 3; grid-row: 1; position: relative; z-index: 1; }
    .about__body { grid-column: 1 / 3; grid-row: 2; position: relative; z-index: 1; }
    .endeavour,
    .endeavour--reversed {
      --endeavour-label-width: var(--space-16);
      --endeavour-media-width: min(
        calc(var(--space-32) * 2),
        calc(100vw - (var(--layout-gutter) * 2) - var(--endeavour-label-width) - var(--space-10))
      );
      grid-template-columns: var(--endeavour-label-width) var(--endeavour-media-width);
      gap: var(--space-10);
      position: relative;
      justify-content: center;
      align-items: start;
      width: fit-content;
      max-width: 100%;
      align-self: center;
    }
    .endeavour .collage__item-img {
      grid-column: 2;
      grid-row: 1;
      width: var(--endeavour-media-width);
      max-width: 100%;
      justify-self: start;
    }
    .endeavour--reversed .collage__item-img { order: -1; }

    .endeavour__text {
      display: contents;
    }

    .endeavour__text .collage__item-title {
      grid-column: 1;
      grid-row: 1;
      align-self: start;
      justify-self: end;
      padding-top: var(--space-2);
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      color: var(--color-brand);
      z-index: var(--z-raised);
    }

    .endeavour--reversed .endeavour__text .collage__item-title {
      grid-column: 2;
      justify-self: start;
      transform: none;
    }

    .endeavour--reversed {
      grid-template-columns: var(--endeavour-media-width) var(--endeavour-label-width);
    }

    .endeavour--reversed .collage__item-img {
      grid-column: 1;
    }

    .endeavour__body {
      grid-column: 1 / -1;
      grid-row: 2;
    }

  }

  @media (max-width: 560px) {
    .page-flow {
      gap: var(--space-16);
    }

    .collage {
      row-gap: var(--space-20);
    }

    .endeavours {
      gap: var(--space-24);
      padding-top: var(--space-20);
      padding-bottom: var(--space-20);
    }

    .endeavour,
    .endeavour--reversed {
