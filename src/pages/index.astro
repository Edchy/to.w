      justify-content: center;
      align-items: start;
      width: fit-content;
      max-width: 100%;
      align-self: center;
    }
    .endeavour .collage__item-img {
      grid-column: 2;
      grid-row: 1;
      width: var(--endeavour-media-width);
      max-width: 100%;
      justify-self: start;
    }
    .endeavour--reversed .collage__item-img { order: -1; }

    .endeavour__text {
      display: contents;
    }

    .endeavour__text .collage__item-title {
      grid-column: 1;
      grid-row: 1;
      align-self: start;
      justify-self: end;
      padding-top: var(--space-2);
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      color: var(--endeavours-text);
      z-index: var(--z-raised);
    }

    .endeavour--reversed .endeavour__text .collage__item-title {
      grid-column: 2;
      justify-self: start;
      transform: none;
    }

    .endeavour--reversed {
      grid-template-columns: var(--endeavour-media-width) var(--endeavour-label-width);
    }

    .endeavour--reversed .collage__item-img {
      grid-column: 1;
    }

    .endeavour__body {
      grid-column: 1 / -1;
      grid-row: 2;
    }

  }

  @media (max-width: 560px) {
    .page-flow {
      gap: var(--space-5xl);
    }

    .collage {
      row-gap: var(--space-20);
    }

    .endeavours {
      gap: var(--space-24);
      padding: var(--space-20) var(--layout-gutter);
      max-width: 100%;
      margin: 0;
    }

    .endeavour,
    .endeavour--reversed {
      --endeavour-label-width: var(--space-12);
      --endeavour-media-width: min(
        calc(var(--space-32) + var(--space-24)),
        calc(100vw - var(--endeavour-label-width) - var(--space-6))
      );
      grid-template-columns: var(--endeavour-label-width) var(--endeavour-media-width);
      gap: var(--space-6);
    }

    .endeavour--reversed {
      grid-template-columns: var(--endeavour-media-width) var(--endeavour-label-width);
    }

    .endeavour .collage__item-img {
      width: var(--endeavour-media-width);
    }

    .endeavour__text .collage__item-title {
      padding-top: var(--space-1);
    }

    .collage__item,
    .collage__deco { grid-column: span 1 !important; margin-top: 0 !important; }
  }

  @media (max-width: 420px) {
    .page-flow {
      gap: var(--space-5xl);
    }

    .endeavours {
      gap: var(--space-24);
      padding-left: var(--layout-gutter);
      padding-right: var(--layout-gutter);
      max-width: 100%;
      margin: 0;
    }

    .endeavour,
    .endeavour--reversed {
      --endeavour-label-width: var(--space-10);
      --endeavour-media-width: min(
        calc(var(--space-32) + var(--space-24)),
        calc(100vw - var(--endeavour-label-width) - var(--space-8))
      );
      gap: var(--space-8);
    }

  }

  /* ── Product links ── */
  .collage__item {
    position: relative;
    overflow: visible;
    display: block;
    text-decoration: none;
    transition: scale var(--duration-fast) var(--ease-out-quart);
    align-self: start;
  }

  .collage__item:active { scale: 0.97; }

  /* ── Decorative ── */
  .collage__deco {
    align-self: start;
    cursor: default;
  }

  /* ── Shared image wrapper ── */
  .collage__item-img {
    width: 100%;
    aspect-ratio: 4 / 5;
    box-sizing: border-box;
    overflow: hidden;
    background: var(--image-border-color);
    position: relative;
    transition: clip-path var(--duration-normal) var(--ease-out-expo);
    will-change: clip-path;
  }

  .collage__item-img--deco {
    aspect-ratio: 2 / 3;
  }

  .collage__item:hover .collage__item-img {
    clip-path: var(--clip-hover) !important;
  }

  .collage__item-img--bordered::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--color-bg-base) 0%, transparent 50%);
    pointer-events: none;
    z-index: 1;
  }

  .collage__item-img--bordered {
    background: var(--color-accent-subtle);
  }

  .collage__item-img img,
  .collage__item-img video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    box-sizing: border-box;
    display: block;
  }

  .collage__item-img--bordered img,
  .collage__item-img--bordered video {
    object-fit: contain !important;
  }

  .gaza-media__video {
    display: none;
  }

  .endeavour__reel {
    display: none;
    color: var(--endeavours-text);
    text-decoration: underline;
    text-underline-offset: var(--underline-offset);
  }

  .endeavour__reel:hover {
    opacity: 0.75;
  }

  .gaza-media__play {
    display: none;
    position: absolute;
    left: 50%;
    top: 50%;
    width: var(--space-12);
    height: var(--space-12);
    padding: 0;
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-full);
    background: var(--color-bg-inverse);
    cursor: pointer;
    place-items: center;
    transform: translate(-50%, -50%);
    transition: scale var(--transition-fast), opacity var(--transition-fast);
    z-index: var(--z-raised);
  }

  .gaza-media__play::before {
    content: "";
    margin-left: var(--space-1);
    border-top: var(--space-2) solid transparent;
    border-bottom: var(--space-2) solid transparent;
    border-left: var(--space-3) solid var(--endeavours-text);
  }

  .gaza-media__play:hover {
    scale: 1.04;
  }

  .gaza-media__play:active {
    scale: 0.96;
  }

  @media (min-width: 761px) {
    .gaza-media__play {
      display: grid;
    }

    .gaza-media--loaded .gaza-media__poster,
    .gaza-media--loaded .gaza-media__play {
      display: none !important;
    }

    .gaza-media--loaded .gaza-media__video {
      display: block;
    }
  }

  /* ── Overlay (products only) ── */
  .collage__item-overlay {
    position: absolute;
    left: 0;
    right: 0;
    pointer-events: none;
    z-index: var(--z-raised);
  }


  .collage__item-title {
    display: block;
    font-family: var(--font-heading-text);
    font-size: var(--font-size-display);
    font-weight: var(--font-weight-regular);
    line-height: var(--font-leading-tight);
    color: var(--color-accent);
    white-space: nowrap;
    letter-spacing: var(--font-tracking-tight);
    transition: color var(--transition-fast);
  }

  .collage__item-meta {
    display: block;
    font-family: var(--font-body-text);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--font-tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent);
    white-space: nowrap;
    margin-top: var(--space-1);
    transition: color var(--transition-fast);
    font-variant-numeric: tabular-nums;
  }

  .collage__item:hover .collage__item-title,
  .collage__item:hover .collage__item-meta {
    color: var(--color-accent-dark);
  }

  @media (max-width: 760px) {
    .collage__item-overlay {
      position: absolute;
      bottom: -1.6em !important;
      left: 0 !important;
      right: 0 !important;
      text-align: left !important;
    }

    .collage__item .collage__item-title {
      font-size: var(--font-size-xl);
      white-space: normal;
    }

    .collage__item-meta {
      white-space: normal;
      font-size: var(--font-size-sm);
      font-family: var(--font-body-text);
      letter-spacing: var(--font-tracking-wide);
      text-transform: uppercase;
      color: var(--color-accent);
      opacity: 1;
    }

    .gaza-media .gaza-media__poster {
      height: 118%;
      object-fit: cover !important;
      object-position: top center;
    }

    .endeavour__reel {
      display: inline;
    }
  }


</style>

<script>
  const INTERVAL = 160;
  const desktopMedia = window.matchMedia("(min-width: 761px)");
  const gazaMedia = document.querySelector<HTMLElement>(".gaza-media");
  const gazaVideo = document.querySelector<HTMLVideoElement>(".gaza-media__video[data-src]");
  const gazaPlay = document.querySelector<HTMLButtonElement>(".gaza-media__play");

  function unloadGazaVideoOnMobile() {
    if (!gazaVideo || !gazaMedia || desktopMedia.matches) return;

    gazaVideo.pause();
    gazaVideo.removeAttribute("src");
    gazaVideo.load();
    gazaMedia.classList.remove("gaza-media--loaded");
  }

  gazaPlay?.addEventListener("click", () => {
    if (!gazaVideo || !gazaMedia || !desktopMedia.matches) return;

    if (!gazaVideo.src) gazaVideo.src = gazaVideo.dataset.src ?? "";
    gazaMedia.classList.add("gaza-media--loaded");
    gazaVideo.play().catch(() => {});
  });

  unloadGazaVideoOnMobile();
  desktopMedia.addEventListener("change", unloadGazaVideoOnMobile);

  document.querySelectorAll<HTMLElement>("[data-cycle-imgs]").forEach((wrap) => {
    const imgs: string[] = JSON.parse(wrap.dataset.cycleImgs!);
    const el = wrap.querySelector<HTMLImageElement>("img");
    if (!el || imgs.length < 2) return;

    let idx = 0;
    setInterval(() => {
      idx = (idx + 1) % imgs.length;
      el.src = imgs[idx];
    }, 4000);
  });

  if (window.matchMedia("(hover: hover)").matches) {
    document.querySelectorAll<HTMLElement>(".collage__deco[data-deco-imgs]").forEach((deco) => {
      const extras: string[] = JSON.parse(deco.dataset.decoImgs!);
      const el = deco.querySelector<HTMLImageElement>("img");
      if (!el || extras.length === 0) return;

      const originalSrc = el.src;
      let timer: ReturnType<typeof setInterval> | null = null;
      let idx = 0;

      deco.addEventListener("mouseenter", () => {
        timer = setInterval(() => {
          el.src = extras[idx % extras.length];
          idx++;
        }, INTERVAL);
      });

      deco.addEventListener("mouseleave", () => {
        if (timer) { clearInterval(timer); timer = null; }
        el.src = originalSrc;
        idx = 0;
      });
    });
  }
</script>
