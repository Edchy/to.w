---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import gazaVideo from "../assets/img/gaza/v-gaza.web.mp4";
import gazaPoster from "../assets/img/gaza/v-gaza-poster.jpg";
import d1handImg from "../assets/img/typ-ett/d1hand.avif";
import typ1Img from "../assets/img/typ-ett/typ1.avif";
import broderJohnImg from "../assets/img/broder-john/broder_john.avif";
import bjInstaImg from "../assets/img/broder-john/bjinsta.avif";
import bjLolImg from "../assets/img/broder-john/bj-lol.avif";
import dontFollowMeImg from "../assets/img/broder-john/dontfollowme.avif";
import toveImg from "../assets/img/tove.avif";
import iconInstagram from "../assets/img/noun-instagram-6788383.svg?raw";
import iconEmail from "../assets/img/noun-send-6788398.svg?raw";
import { CONTACT_EMAIL, CONTACT_EMAIL_HREF, getProductSlug } from "../config/site";

const gazaReelUrl = "https://www.instagram.com/reel/DRMmx_ODFXL/?igsh=MTEwdzV6d3Frc3F5ZQ==";

const allJewelry = await getCollection("jewelry");
const allKnitting = await getCollection("knitting");

const byDate = (a: { data: { date: string } }, b: { data: { date: string } }) =>
  b.data.date.localeCompare(a.data.date);

const jewelry = allJewelry.sort(byDate);
const knitting = allKnitting.sort(byDate);
const works = [
  ...jewelry.map((entry) => ({ kind: "jewelry" as const, entry })),
  ...knitting.map((entry) => ({ kind: "knitting" as const, entry })),
].sort((a, b) => b.entry.data.date.localeCompare(a.entry.data.date));
const workRows = [
  works.slice(0, 2),
  works.slice(2, 4),
  works.slice(4, 6),
  works.slice(6, 8),
  works.slice(8, 10),
].filter((row) => row.length > 0);

const fmt = new Intl.NumberFormat("sv-SE").format;
const baseUrl = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/`;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;
---

<BaseLayout description="to.w — handgjorda smycken och objekt.">
  <div class="home">
    <h1 class="sr-only">Tove Wätte — handgjorda smycken och stickning</h1>

    {workRows.map((row, rowIndex) => (
      <>
        <section class:list={["work", `work--row-${rowIndex + 1}`]} aria-label={`Verk rad ${rowIndex + 1}`}>
          {row.map(({ kind, entry }, i) => {
            const globalIndex = rowIndex * 2 + i;
            const productSlug = getProductSlug(entry.id);
            const href = withBase(kind === "jewelry" ? `/smycken/${productSlug}` : `/stickning/${productSlug}`);
            return (
              <a class="work-card" href={href} aria-label={`Visa ${entry.data.title}`}>
                <figure class="work-card__figure">
                  <div class="work-card__media" transition:name={`product-${productSlug}`}>
                    <Image
                      src={entry.data.images[0]}
                      alt={entry.data.title}
                      loading={globalIndex < 4 ? "eager" : "lazy"}
                      fetchpriority={globalIndex === 0 ? "high" : "auto"}
                      width={720}
                      height={900}
                    />
                  </div>
                  <figcaption class="work-card__caption">
                    <h2 class="work-card__title" transition:name={`product-title-${productSlug}`} transition:animate="none">{entry.data.title}</h2>
                    <span class="work-card__price">{fmt(entry.data.price)} kr</span>
                    {entry.data.description && (
                      <>
                        <p class="work-card__description">{entry.data.description}</p>
                        <span class="work-card__read-more" aria-hidden="true">läs mer</span>
                      </>
                    )}
                  </figcaption>
                </figure>
              </a>
            );
          })}
        </section>

        {rowIndex === 0 && (
          <article class="project project--gaza" aria-label="Projekt Gaza">
            <div class="project__media gaza-media">
              <Image class="gaza-media__poster" src={gazaPoster} alt="Gaza-halsbandet" loading="lazy" width={640} height={800} />
              <button class="gaza-media__play" type="button" aria-label="Spela Gaza-video"></button>
              <video
                class="gaza-media__video"
                data-src={gazaVideo}
                poster={gazaPoster.src}
                aria-label="Gaza-halsbandet"
                playsinline
                controls
                preload="metadata"
              ></video>
            </div>
            <div class="project__text">
              <h2>Gaza</h2>
              <p>Ett halsband graverat på återvunnet sterling silver, skapat i samarbete med <a href="https://www.instagram.com/vtelegin" target="_blank" rel="noopener noreferrer">Viktor Telegin</a>. 20 exemplar — alla intäkter gick till Rädda Barnen och deras arbete för barn i Gaza. <a class="project__reel" href={gazaReelUrl} target="_blank" rel="noopener noreferrer">Se video</a></p>
            </div>
          </article>
        )}

        {rowIndex === 1 && (
          <article class="project project--reverse" aria-label="Projekt Typ Ett">
            <div class="project__media project__media--pair">
              <Image src={d1handImg} alt="D1-ringen" loading="lazy" width={640} height={800} />
              <Image src={typ1Img} alt="Typ Ett-ringen" loading="lazy" width={640} height={800} />
            </div>
            <div class="project__text">
              <h2>Typ Ett</h2>
              <p>En tunn ring med en knut högst upp, designad exklusivt för <a href="https://webbshop.barndiabetesfonden.se/produkter/knut-ring-silver" target="_blank" rel="noopener noreferrer">Barndiabetesfonden</a>. Alla intäkter går till forskning om typ 1 diabetes.</p>
            </div>
          </article>
        )}

        {rowIndex === 2 && (
          <article class="project" aria-label="Projekt hoop hoop">
            <div class="project__media project__media--quad">
              <Image src={broderJohnImg} alt="Broder John" loading="lazy" width={640} height={640} />
              <Image src={bjInstaImg} alt="Broder John på Instagram" loading="lazy" width={640} height={640} />
              <Image src={bjLolImg} alt="Broder John" loading="lazy" width={640} height={640} />
              <Image src={dontFollowMeImg} alt="Broder John-ring" loading="lazy" width={640} height={640} />
            </div>
            <div class="project__text">
              <h2>hoop hoop</h2>
              <p>Har haft den stora äran att få göra ett par ringar åt <a href="https://open.spotify.com/artist/66iUd3sGrtkATTS7FHWPe4?si=3z2af2KrRsuGUudeJo890A" target="_blank" rel="noopener noreferrer">Broder John</a> och hans <a href="https://www.hoopdiggas.com/" target="_blank" rel="noopener noreferrer">Hoopdiggas</a>.</p>
            </div>
          </article>
        )}
      </>
    ))}

    <section class="about" aria-label="Om">
      <Image class="about__photo" src={toveImg} alt="Porträtt av konstnären" loading="lazy" width={420} height={520} />
      <div class="about__text">
        <p class="about__intro">Hej, jag heter Tove Wätte och gör smycken i min studio i Järna, utanför Stockholm.</p>
        <p>Jag arbetar främst med silver, ofta återvunnet. Allt görs för hand med omsorg och kärlek, vilket gör att varje del blir lite unik.</p>
        <p>Jag designar även stickmönster som ett sätt att utforska form och struktur på ett annat sätt än i metallen.</p>
        <div class="about__links">
          <a href="https://instagram.com/tovewatte" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <Fragment set:html={iconInstagram} />
          </a>
          <a href={CONTACT_EMAIL_HREF} aria-label={`E-post: ${CONTACT_EMAIL}`}>
            <Fragment set:html={iconEmail} />
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home {
    max-width: var(--layout-wide-width);
    margin: 0 auto;
    padding: var(--space-8) var(--layout-gutter) var(--space-24);
  }

  .work {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: clamp(var(--space-4), 2.2vw, var(--space-10));
    row-gap: clamp(var(--space-24), 12vw, var(--space-72));
    align-items: start;
  }

  .project + .work {
    margin-top: clamp(var(--space-24), 12vw, var(--space-72));
  }

  .work + .project,
  .work + .about {
    margin-top: clamp(var(--space-32), 15vw, var(--space-72));
  }

  .work-card {
    --work-frame: var(--color-bg-muted);
    --work-frame-hover: var(--color-accent-subtle);
    --work-tilt: -1.5deg;
    --reveal-x: 0;
    --reveal-rot: 0deg;
    grid-column: span 3;
    display: block;
    color: var(--color-text-primary);
  }

  .work-card:nth-child(6n + 1) {
    --work-frame: var(--color-accent-subtle);
    --work-frame-hover: var(--color-bg-muted);
    --work-tilt: 1.4deg;
    --reveal-x: calc(var(--space-6) * -1);
    --reveal-rot: -1.6deg;
    grid-column: 1 / span 4;
  }

  .work-card:nth-child(6n + 2) {
    --work-frame: var(--color-brand-subtle);
    --work-frame-hover: var(--color-accent-subtle);
    --work-tilt: -2.2deg;
    --reveal-x: var(--space-8);
    --reveal-rot: 1.2deg;
    grid-column: 8 / span 3;
    margin-top: var(--space-20);
  }

  .work-card:nth-child(6n + 3) {
    --work-frame: var(--color-bg-surface);
    --work-frame-hover: var(--color-brand-subtle);
    --work-tilt: 1deg;
    --reveal-x: calc(var(--space-4) * -1);
    --reveal-rot: -0.8deg;
    grid-column: 3 / span 3;
    margin-top: var(--space-6);
  }

  .work--row-2 .work-card:nth-child(1) {
    grid-column: 2 / span 3;
    margin-top: var(--space-12);
  }

  .work--row-2 .work-card:nth-child(2) {
    grid-column: 8 / span 4;
    margin-top: var(--space-20);
  }

  .work--row-3 .work-card:nth-child(1) {
    grid-column: 1 / span 4;
    margin-top: var(--space-16);
  }

  .work--row-3 .work-card:nth-child(2) {
    grid-column: 7 / span 4;
    margin-top: 0;
  }

  .work--row-4 .work-card:nth-child(1) {
    grid-column: 3 / span 3;
  }

  .work--row-4 .work-card:nth-child(2) {
    grid-column: 8 / span 3;
    margin-top: var(--space-20);
  }

  .work--row-5 .work-card:nth-child(1) {
    grid-column: 1 / span 4;
    margin-top: var(--space-12);
  }

  .work--row-5 .work-card:nth-child(2) {
    grid-column: 7 / span 3;
    margin-top: var(--space-24);
  }

  .work-card:nth-child(6n + 4) {
    --work-frame: var(--color-bg-muted);
    --work-frame-hover: var(--color-brand-subtle);
    --work-tilt: -1.3deg;
    --reveal-x: var(--space-6);
    --reveal-rot: 1.5deg;
    grid-column: 7 / span 4;
    margin-top: var(--space-24);
  }

  .work-card:nth-child(6n + 5) {
    --work-frame: var(--color-brand-subtle);
    --work-frame-hover: var(--color-bg-muted);
    --work-tilt: 1.8deg;
    --reveal-x: calc(var(--space-8) * -1);
    --reveal-rot: -1deg;
    grid-column: 2 / span 3;
    margin-top: var(--space-12);
  }

  .work-card:nth-child(6n) {
    --work-frame: var(--color-accent-subtle);
    --work-frame-hover: var(--color-brand-subtle);
    --work-tilt: -1deg;
    --reveal-x: var(--space-4);
    --reveal-rot: 0.8deg;
    grid-column: 9 / span 3;
  }

  .work-card__figure {
    margin: 0;
    display: grid;
    gap: 0;
    position: relative;
  }

  .work-card__media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--work-frame);
    border: var(--space-2) solid var(--work-frame);
    border-bottom-width: var(--space-4);
    border-radius: var(--radius-sm);
    padding: var(--space-2);
    box-shadow: 0 var(--space-2) 0 color-mix(in oklch, var(--color-text-primary) 8%, transparent);
    transform-origin: 50% 62%;
    position: relative;
    z-index: 1;
    transition:
      background-color var(--transition-slow),
      border-color var(--transition-slow),
      box-shadow var(--transition-slow),
      filter var(--transition-normal),
      transform var(--transition-slow);
  }

  .work-card__media::after {
    content: "";
    position: absolute;
    inset: var(--space-2);
    border: 1px solid color-mix(in oklch, var(--color-text-primary) 9%, transparent);
    border-radius: var(--radius-sm);
    opacity: 0.7;
    pointer-events: none;
    transition:
      opacity var(--transition-normal),
      transform var(--transition-slow);
  }

  .work-card__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    border-radius: var(--radius-sm);
    transition:
      filter var(--transition-slow),
      transform var(--transition-slow);
  }

  .work-card__caption {
    display: grid;
    gap: var(--space-1);
    position: relative;
    z-index: 2;
    padding-top: 0;
    margin-top: calc(var(--space-8) * -1);
    transform: translateX(calc(var(--space-3) * -1));
    transition: transform var(--transition-slow);
  }

  .work-card__title {
    width: fit-content;
    max-width: 8ch;
    font-size: clamp(2.1rem, 4.2vw, 5.4rem);
    font-weight: var(--font-weight-regular);
    line-height: 0.9;
    letter-spacing: var(--font-tracking-tightest);
    position: relative;
  }

  .work-card__title::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.12em;
    height: 1px;
    background: currentColor;
    opacity: 0;
    transform: scaleX(0.35);
    transform-origin: left;
    transition:
      opacity var(--transition-normal),
      transform var(--transition-slow);
  }

  .work-card__price {
    width: fit-content;
    padding: var(--space-1) var(--space-2);
    background: var(--color-bg-base);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    letter-spacing: var(--font-tracking-wide);
    font-variant-numeric: tabular-nums;
    transition:
      color var(--transition-normal),
      opacity var(--transition-normal),
      transform var(--transition-normal);
  }

  .work-card__description {
    max-width: 30ch;
    margin: var(--space-2) 0 0;
    font-size: var(--font-size-sm);
    line-height: var(--font-leading-snug);
    color: var(--color-text-secondary);
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    text-wrap: pretty;
    transition:
      color var(--transition-normal),
      transform var(--transition-slow);
  }

  .work-card__read-more {
    width: fit-content;
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
    line-height: var(--font-leading-tight);
    color: var(--color-brand);
    text-decoration: underline;
    text-underline-offset: var(--underline-offset);
    transition:
      color var(--transition-normal),
      opacity var(--transition-normal),
      transform var(--transition-slow);
  }

  @media (hover: hover) {
    .work-card:hover .work-card__media {
      background-color: var(--work-frame-hover);
      border-color: var(--work-frame-hover);
      box-shadow: var(--space-2) var(--space-3) 0 color-mix(in oklch, var(--color-text-primary) 13%, transparent);
      filter: saturate(1.02);
      transform: translateY(calc(var(--space-2) * -1)) rotate(var(--work-tilt)) scale(1.025);
    }

    .work-card:hover .work-card__media::after {
      opacity: 0.25;
      transform: scale(0.96);
    }

    .work-card:hover .work-card__media img {
      filter: contrast(1.02) saturate(0.95);
      transform: scale(1.055) rotate(calc(var(--work-tilt) * -0.7));
    }

    .work-card:hover .work-card__caption {
      transform: translate(calc(var(--space-1) * -1), calc(var(--space-2) * -1));
    }

    .work-card:hover .work-card__title::after {
      opacity: 0.55;
      transform: scaleX(1);
    }

    .work-card:hover .work-card__price {
      color: var(--color-text-primary);
      transform: translateX(var(--space-1));
    }

    .work-card:hover .work-card__description {
      color: var(--color-text-primary);
      transform: translateX(var(--space-1));
    }

    .work-card:hover .work-card__read-more {
      color: var(--color-accent);
      transform: translateX(var(--space-1));
    }
  }

  .about {
    display: grid;
    grid-template-columns: minmax(180px, 0.34fr) minmax(0, 1fr);
    gap: clamp(var(--space-8), 6vw, var(--space-24));
    align-items: start;
    max-width: var(--layout-statement-width);
  }

  .about__photo {
    width: min(100%, 320px);
    height: auto;
    border-radius: var(--radius-sm);
    filter: saturate(0.86);
  }

  .about__text {
    max-width: 64ch;
    display: grid;
    gap: var(--space-5);
    font-size: var(--font-size-lg);
    line-height: var(--font-leading-relaxed);
  }

  .about__intro {
    font-family: var(--font-heading-text);
    font-size: var(--font-size-2xl);
    line-height: var(--font-leading-snug);
  }

  .about__links {
    display: flex;
    gap: var(--space-4);
    padding-top: var(--space-2);
  }

  .about__links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    color: var(--color-brand);
    transition: opacity var(--transition-fast);
  }

  .about__links a:hover {
    opacity: 0.7;
  }

  .about__links :global(svg) {
    width: 30px;
    height: 30px;
    fill: currentColor;
  }

  .project {
    display: grid;
    grid-template-columns: minmax(280px, 0.92fr) minmax(0, 0.72fr);
    gap: clamp(var(--space-8), 6vw, var(--space-24));
    align-items: center;
    padding-top: clamp(var(--space-12), 5vw, var(--space-20));
    border-top: 1px solid var(--color-border-subtle);
    max-width: var(--layout-wide-width);
  }

  .project--reverse {
    grid-template-columns: minmax(0, 0.72fr) minmax(280px, 0.92fr);
  }

  .project--reverse .project__media {
    order: 2;
  }

  .project__media {
    width: 100%;
    aspect-ratio: 5 / 4;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-bg-surface);
    filter: saturate(0.88);
    transition:
      background-color var(--transition-slow),
      filter var(--transition-slow),
      transform var(--transition-slow);
  }

  img.project__media {
    height: 100%;
    object-fit: contain;
  }

  .project__media--pair,
  .project__media--quad {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-4);
    border: var(--space-2) solid var(--color-bg-muted);
    border-top-width: var(--space-4);
  }

  .project__media--pair {
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
  }

  .project__media--quad {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .project__media--pair img,
  .project__media--quad img {
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    border-radius: var(--radius-sm);
    transition:
      filter var(--transition-slow),
      transform var(--transition-slow);
  }

  .project__media--pair img {
    object-fit: contain;
    background: color-mix(in oklch, var(--color-bg-base) 76%, var(--color-bg-surface));
  }

  .project__text {
    max-width: 58ch;
    display: grid;
    gap: var(--space-5);
    position: relative;
    z-index: 2;
  }

  .project__text h2 {
    width: max-content;
    max-width: 7ch;
    font-size: clamp(3.8rem, 9vw, 9.4rem);
    font-weight: var(--font-weight-regular);
    line-height: 0.82;
    transform: translateX(calc(var(--space-20) * -1));
    transition:
      color var(--transition-slow),
      transform var(--transition-slow);
  }

  .project--reverse .project__text h2 {
    transform: translateX(var(--space-20));
    justify-self: end;
    text-align: right;
  }

  .project__text p {
    color: var(--color-text-secondary);
    line-height: var(--font-leading-relaxed);
  }

  .project__text a {
    color: var(--color-text-primary);
    text-decoration: underline;
    text-underline-offset: var(--underline-offset);
    transition: color var(--transition-normal), opacity var(--transition-normal);
  }

  @media (hover: hover) {
    .project:hover .project__text h2 {
      color: var(--color-accent);
      transform: translateX(calc(var(--space-16) * -1));
    }

    .project--reverse:hover .project__text h2 {
      transform: translateX(var(--space-16));
    }

    .project:hover .project__media {
      filter: saturate(1);
    }

    .project__text a:hover {
      color: var(--color-brand);
      opacity: 0.82;
    }
  }

  .gaza-media {
    position: relative;
    border: var(--space-2) solid var(--color-bg-muted);
    border-top-width: var(--space-4);
    padding: var(--space-4);
  }

  .gaza-media__poster,
  .gaza-media__video {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: var(--color-bg-surface);
    border-radius: var(--radius-sm);
    transition:
      filter var(--transition-slow),
      transform var(--transition-slow);
  }

  .gaza-media__video {
    display: none;
  }

  .gaza-media__play {
    display: none;
    position: absolute;
    left: 50%;
    top: 50%;
    width: var(--space-12);
    height: var(--space-12);
    padding: 0;
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-full);
    background: var(--color-bg-inverse);
    cursor: pointer;
    place-items: center;
    transform: translate(-50%, -50%);
    transition:
      opacity var(--transition-fast),
      scale var(--transition-fast),
      transform var(--transition-normal);
    z-index: var(--z-raised);
  }

  .gaza-media__play::before {
    content: "";
    display: block;
    margin-left: var(--space-1);
    border-top: var(--space-2) solid transparent;
    border-bottom: var(--space-2) solid transparent;
    border-left: var(--space-3) solid var(--color-text-inverse);
  }

  .project__reel {
    display: none;
  }

  @media (min-width: 761px) {
    .gaza-media__play {
      display: grid;
    }

    .gaza-media--loaded .gaza-media__poster,
    .gaza-media--loaded .gaza-media__play {
      display: none;
    }

    .gaza-media--loaded .gaza-media__video {
      display: block;
    }
  }

  @media (hover: hover) {
    .project:hover .project__media--pair img:first-child,
    .project:hover .project__media--quad img:nth-child(2),
    .project:hover .gaza-media__poster {
      transform: scale(1.035) rotate(-0.6deg);
    }

    .project:hover .project__media--pair img:last-child,
    .project:hover .project__media--quad img:nth-child(3),
    .project:hover .gaza-media__video {
      transform: scale(1.035) rotate(0.6deg);
    }

    .project:hover .project__media--quad img:first-child {
      transform: scale(1.025) rotate(0.4deg);
    }

    .project:hover .project__media--quad img:last-child {
      transform: scale(1.025) rotate(-0.4deg);
    }
  }

  @keyframes quiet-rise {
    from {
      opacity: 0;
      transform: translate(var(--reveal-x, 0), var(--space-8)) rotate(var(--reveal-rot, 0deg)) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translate(0, 0) rotate(0deg) scale(1);
    }
  }

  .work-card,
  .about,
  .project {
    animation: quiet-rise 420ms var(--ease-out-expo) both;
    animation-play-state: paused;
  }

  .is-visible {
    animation-play-state: running;
  }

  @media (max-width: 920px) {
    .home {
      padding-top: var(--space-6);
    }

    .work {
      grid-template-columns: repeat(6, minmax(0, 1fr));
      row-gap: var(--space-32);
    }

    .work-card,
    .work-card:nth-child(n),
    .work.work--row-2 .work-card:nth-child(n),
    .work.work--row-3 .work-card:nth-child(n),
    .work.work--row-4 .work-card:nth-child(n),
    .work.work--row-5 .work-card:nth-child(n) {
      grid-column: span 3;
      margin-top: 0;
    }

    .work-card:nth-child(4n + 2),
    .work-card:nth-child(4n + 3) {
      margin-top: var(--space-16);
    }

    .about,
    .project {
      grid-template-columns: 1fr;
    }

    .project--reverse {
      grid-template-columns: 1fr;
    }

    .project--reverse .project__media {
      order: 0;
    }

    .project__text h2,
    .project--reverse .project__text h2 {
      transform: none;
      justify-self: start;
      text-align: left;
    }

    .about__photo,
    .project__media {
      max-width: 640px;
    }
  }

  @media (max-width: 560px) {
    .home {
      padding-bottom: var(--space-16);
    }

    .work {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: var(--space-3);
      row-gap: var(--space-20);
    }

    .work-card,
    .work-card:nth-child(n),
    .work.work--row-2 .work-card:nth-child(n),
    .work.work--row-3 .work-card:nth-child(n),
    .work.work--row-4 .work-card:nth-child(n),
    .work.work--row-5 .work-card:nth-child(n) {
      grid-column: span 1;
      margin-top: 0;
    }

    .work-card:nth-child(even) {
      margin-top: var(--space-10);
    }

    .work-card__title,
    .work-card:nth-child(n) .work-card__title {
      font-size: var(--font-size-xl);
      max-width: 9ch;
    }

    .work-card__price {
      font-size: var(--font-size-xs);
    }

    .work-card__description {
      max-width: 24ch;
      font-size: var(--font-size-xs);
      -webkit-line-clamp: 2;
    }

    .work-card__read-more {
      font-size: var(--font-size-xs);
    }

    .about__text {
      font-size: var(--font-size-base);
    }

    .about__intro {
      font-size: var(--font-size-xl);
    }

    .project {
      padding-top: var(--space-12);
    }

    .project__text h2 {
      font-size: var(--font-size-2xl);
    }

    .project__media {
      aspect-ratio: 4 / 5;
    }

    .project__media--pair {
      grid-template-columns: 1fr;
      aspect-ratio: auto;
    }

    .project__media--pair img {
      aspect-ratio: 4 / 5;
    }

    .project__media--quad {
      aspect-ratio: 1 / 1;
    }

    .project__reel {
      display: inline;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card,
    .about,
    .project {
      animation: none;
    }
  }
</style>

<script>
  function initIndexInteractions() {
    const desktopMedia = window.matchMedia("(min-width: 761px)");
    const gazaMedia = document.querySelector<HTMLElement>(".gaza-media");
    const gazaVideo = document.querySelector<HTMLVideoElement>(".gaza-media__video[data-src]");
    const gazaPlay = document.querySelector<HTMLButtonElement>(".gaza-media__play");

    function unloadGazaVideoOnMobile() {
      if (!gazaVideo || !gazaMedia || desktopMedia.matches) return;

      gazaVideo.pause();
      gazaVideo.removeAttribute("src");
      gazaVideo.load();
      gazaMedia.classList.remove("gaza-media--loaded");
    }

    gazaPlay?.addEventListener("click", () => {
      if (!gazaVideo || !gazaMedia || !desktopMedia.matches) return;

      if (!gazaVideo.src) gazaVideo.src = gazaVideo.dataset.src ?? "";
      gazaMedia.classList.add("gaza-media--loaded");
      gazaVideo.play().catch(() => {});
    });

    unloadGazaVideoOnMobile();
    desktopMedia.addEventListener("change", unloadGazaVideoOnMobile);

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      document.querySelectorAll<HTMLElement>(".work-card, .about, .project").forEach((el) => {
        el.classList.add("is-visible");
      });
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -32px 0px" }
    );

    document.querySelectorAll<HTMLElement>(".work-card, .about, .project").forEach((el, index) => {
      el.style.animationDelay = `${Math.min(index % 4, 3) * 55}ms`;
      observer.observe(el);
    });
  }

  document.addEventListener("astro:page-load", initIndexInteractions);
</script>
