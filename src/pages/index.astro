---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import gazaVideo from "../assets/img/v-gaza.web.mp4";
import gazaPoster from "../assets/img/v-gaza-poster.jpg";
import d1handImg from "../assets/img/d1hand.avif";
import typ1Img from "../assets/img/typ1.avif";
import toveImg from "../assets/img/tove.avif";
import iconInstagram from "../assets/img/noun-instagram-6788383.svg?raw";
import iconEmail from "../assets/img/noun-send-6788398.svg?raw";
import { CONTACT_EMAIL, CONTACT_EMAIL_HREF, getProductSlug } from "../config/site";

const gazaReelUrl = "https://www.instagram.com/reel/DRMmx_ODFXL/?igsh=MTEwdzV6d3Frc3F5ZQ==";

const allJewelry  = await getCollection("jewelry");
const allKnitting = await getCollection("knitting");

const decoSlotImports = import.meta.glob<{ default: ImageMetadata }>(
  "../content/decorative/slot-*/*.{jpg,jpeg,webp,avif,png}",
  { eager: true }
);
const decoBySlot: ImageMetadata[][] = [];
for (const [path, mod] of Object.entries(decoSlotImports)) {
  const match = path.match(/slot-(\d+)/);
  if (!match) continue;
  const idx = Number(match[1]);
  (decoBySlot[idx] ??= []).push(mod.default);
}
const allDeco = decoBySlot.map((imgs) => imgs?.[0]).filter(Boolean) as ImageMetadata[];

const byDate = (a: { data: { date: string } }, b: { data: { date: string } }) =>
  b.data.date.localeCompare(a.data.date);

const jewelry  = allJewelry.sort(byDate);
const knitting = allKnitting.sort(byDate);


type ProductEntry = typeof jewelry[0] | typeof knitting[0];
type GridItem =
  | { kind: "jewelry" | "knitting"; entry: ProductEntry; img?: undefined; decoSlot?: undefined; span?: number }
  | { kind: "decorative"; entry?: undefined; img: ImageMetadata; decoSlot: number; span?: number }
  | { kind: "empty"; entry?: undefined; img?: undefined; decoSlot?: undefined; span?: number };

const J = (i: number, span = 1): GridItem => ({ kind: "jewelry",    entry: jewelry[i],  span });
const K = (i: number, span = 1): GridItem => ({ kind: "knitting",   entry: knitting[i], span });
const D = (i: number, span = 1): GridItem => ({ kind: "decorative", img: allDeco[i], decoSlot: i, span });

const gridAB: GridItem[] = [
  // Row 1
  J(0), D(0), K(0),
  // Row 2
  K(1), J(1), D(1),
  // Row 3
  D(2), J(2), K(2),
  // Row 4
  J(3), D(3), J(4),
];

const gridC: GridItem[] = [
  // Row 5
  D(4), D(5), J(5),
];

// 3-column grid slots — fixed pattern, rows always sum to 3
const slots: { span: number; nudge: string }[] = [
  { span: 1, nudge: "0px"  },
  { span: 1, nudge: "28px" },
  { span: 1, nudge: "12px" },
  { span: 2, nudge: "0px"  },
  { span: 1, nudge: "36px" },
  { span: 1, nudge: "20px" },
  { span: 1, nudge: "8px"  },
  { span: 1, nudge: "32px" },
  { span: 1, nudge: "16px" },
  { span: 1, nudge: "0px"  },
  { span: 2, nudge: "16px" },
  { span: 1, nudge: "44px" },
  { span: 1, nudge: "8px"  },
];

// Asymmetric image padding (top right bottom left)
const borderPaddings: string[] = [
  "0 0 12% 0",
  "0 14% 0 0",
  "13% 0 0 0",
  "0 0 0 14%",
  "0 10% 12% 0",
  "11% 0 0 10%",
  "0 0 13% 11%",
  "10% 12% 0 0",
  "13% 0 11% 0",
  "0 11% 0 13%",
];

const insets: [number, number, number, number][] = [
  [3.5, 2.8, 4.2, 3.1],
  [4.1, 2.6, 3.0, 4.4],
  [3.8, 3.2, 2.7, 3.5],
  [2.4, 4.0, 3.7, 2.8],
  [3.0, 3.5, 4.3, 2.6],
  [4.5, 2.9, 3.2, 3.8],
  [2.6, 3.7, 4.0, 2.9],
  [3.6, 2.7, 3.3, 4.2],
  [4.0, 3.1, 2.5, 3.9],
];

const cornerOffsets: [number,number,number,number,number,number,number,number][] = [
  [ 0.3, 0.2,-0.2, 0.4, 0.1,-0.3,-0.4, 0.1],
  [-0.2, 0.3, 0.4,-0.1,-0.3, 0.2, 0.2,-0.4],
  [ 0.1,-0.4, 0.3, 0.2,-0.2, 0.4,-0.3,-0.1],
  [-0.3, 0.1,-0.1, 0.4, 0.4,-0.2, 0.2, 0.3],
  [ 0.4,-0.2, 0.1, 0.3,-0.4, 0.1, 0.3,-0.3],
  [-0.1, 0.4,-0.3,-0.2, 0.2, 0.3,-0.4, 0.1],
  [ 0.2, 0.3, 0.4,-0.3,-0.1, 0.2, 0.3,-0.4],
  [-0.4, 0.1, 0.2, 0.4, 0.3,-0.1,-0.2, 0.3],
  [ 0.3,-0.3,-0.2, 0.1, 0.4, 0.2,-0.1,-0.4],
];


const textOffsets: { bottom: string; left?: string; right?: string; textAlign?: string }[] = [
  { bottom: "-2.4em",  left: "0"                             },
  { bottom: "-4.8em",  left: "0"                             },
  { bottom: "-2.8em",  right: "0",      textAlign: "right"   },
  { bottom: "-2.0em",  left: "0",      textAlign: "left"   },
  { bottom: "-4.0em",  left: "0"                             },
  { bottom: "-5.6em",  right: "0",      textAlign: "right"   },
  { bottom: "-1.6em",  left: "60%"                           },
  { bottom: "-3.2em",  left: "0"                             },
  { bottom: "-4.8em",  right: "0",      textAlign: "right"   },
  { bottom: "-3.2em",  right: "20%",    textAlign: "right"   },
];

const fmt = new Intl.NumberFormat("sv-SE").format;
const baseUrl = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/`;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;

function overlayStyle(idx: number): string {
  const o = textOffsets[idx % textOffsets.length];
  const parts = [`bottom:${o.bottom}`];
  if (o.left  !== undefined) parts.push(`left:${o.left}`);
  if (o.right !== undefined) parts.push(`right:${o.right}`);
  if (o.textAlign)           parts.push(`text-align:${o.textAlign}`);
  return parts.join(";");
}

function makeClip(
  [top, right, bottom, left]: [number, number, number, number],
  [o0, o1, o2, o3, o4, o5, o6, o7]: [number,number,number,number,number,number,number,number]
): string {
  const t = top, r = 100 - right, b = 100 - bottom, l = left;
  return [
    `${l + o0}% ${t + o1}%`,
    `${r + o2}% ${t + o3}%`,
    `${r + o4}% ${b + o5}%`,
    `${l + o6}% ${b + o7}%`,
  ].join(", ");
}

function makeClipHover(
  [top, right, bottom, left]: [number, number, number, number],
  [o0, o1, o2, o3, o4, o5, o6, o7]: [number,number,number,number,number,number,number,number]
): string {
  // Expand outward: reduce insets by ~65%
  const f = 0.35;
  const t = top * f, r = 100 - right * f, b = 100 - bottom * f, l = left * f;
  return [
    `${l + o0 * f}% ${t + o1 * f}%`,
    `${r + o2 * f}% ${t + o3 * f}%`,
    `${r + o4 * f}% ${b + o5 * f}%`,
    `${l + o6 * f}% ${b + o7 * f}%`,
  ].join(", ");
}
---

<BaseLayout description="to.w — handmade jewelry and objects.">
  <div class="page-flow">
    <h1 class="sr-only">Tove Wätte — handmade jewelry and knitting</h1>

    <section class="collage" aria-label="Works — part 1">
      {gridAB.slice(0, 6).map((item, i) => {
        const slot          = slots[i % slots.length];
        const inset         = insets[i % insets.length];
        const offsets       = cornerOffsets[i % cornerOffsets.length];
        const clipRest      = `polygon(${makeClip(inset, offsets)})`;
        const clipHover     = `polygon(${makeClipHover(inset, offsets)})`;
        const borderPadding = borderPaddings[i % borderPaddings.length];
        const itemStyle     = `grid-column: span ${item.span}; margin-top: ${slot.nudge};`;
        const imgStyle      = `--clip-rest:${clipRest};--clip-hover:${clipHover};clip-path:var(--clip-rest);`;
        if (item.kind === "empty") return <div style={itemStyle} aria-hidden="true" />;
        if (item.kind === "decorative") return (
          <div class="collage__deco" style={itemStyle} data-deco-imgs={JSON.stringify((decoBySlot[item.decoSlot] ?? []).slice(1).map(img => img.src))}>
            <div class="collage__item-img collage__item-img--deco" style={imgStyle}>
              <Image src={item.img} alt="" width={600} height={900} loading="lazy" style={`padding: ${borderPadding};`} />
            </div>
          </div>
        );
        const { entry, kind } = item;
        const productSlug = getProductSlug(entry.id);
        const href = withBase(kind === "jewelry" ? `/smycken/${productSlug}` : `/stickning/${productSlug}`);
        return (
          <a class:list={["collage__item", `collage__item--${kind}`]} href={href} style={itemStyle} aria-label={`View ${entry.data.title}`}>
            <div class="collage__item-img collage__item-img--bordered" style={imgStyle} transition:name={`product-${productSlug}`}>
              <Image src={entry.data.images[0]} alt={entry.data.title} loading={i < 3 ? "eager" : "lazy"} width={600} height={600} style={`padding: ${borderPadding};`} />
            </div>
            <div class="collage__item-overlay" style={overlayStyle(i)} aria-hidden="true">
              <h2 class="collage__item-title" transition:name={`product-title-${productSlug}`} transition:animate="none">{entry.data.title}</h2>
              <span class="collage__item-meta">{fmt(entry.data.price)} kr</span>
            </div>
          </a>
        );
      })}
    </section>

    <!-- About -->
    <section class="interlude interlude--about" aria-label="About">
      <div class="about__photo-wrap">
        <Image class="about__photo" src={toveImg} alt="Portrait of the artist" loading="lazy" width={400} height={500} />
      </div>
      <p class="about__headline">
      Hello,
      </p>
      <p class="about__body">
      My name is Tove Wätte. I make jewelry and knitwear from my studio in Järna, outside Stockholm. Self-taught, and at it for over ten years now.
        I work with silver and wool, often recycled. Every piece is made by hand and takes time, love and care. That means every piece is a little different. In a world full of mass production, I think that matters.
      </p>
      <p class="about__body about__body--cta">
        For the latest work, upcoming workshops, and everything in between — check my <a class="about__inline-link" href="https://instagram.com/tovewatte" target="_blank" rel="noopener noreferrer">instagram</a>.<br/> For questions, special requests, or anything else — <a class="about__inline-link" href={CONTACT_EMAIL_HREF}>email me</a>.
      </p>
      <ul class="about__socials" role="list">
        <li>
          <a href="https://instagram.com/tovewatte" target="_blank" rel="noopener noreferrer" aria-label="Instagram" data-label="@tovewatte">
            <Fragment set:html={iconInstagram} />
          </a>
        </li>
        <li>
          <a href={CONTACT_EMAIL_HREF} aria-label="Email" data-label={CONTACT_EMAIL}>
            <Fragment set:html={iconEmail} />
          </a>
        </li>
      </ul>
    </section>

    <section class="collage" aria-label="Works — part 1b">
      {gridAB.slice(6).map((item, i) => {
        const si            = i + 6;
        const slot          = slots[si % slots.length];
        const inset         = insets[si % insets.length];
        const offsets       = cornerOffsets[si % cornerOffsets.length];
        const clipRest      = `polygon(${makeClip(inset, offsets)})`;
        const clipHover     = `polygon(${makeClipHover(inset, offsets)})`;
        const borderPadding = borderPaddings[si % borderPaddings.length];
        const itemStyle     = `grid-column: span ${item.span}; margin-top: ${slot.nudge};`;
        const imgStyle      = `--clip-rest:${clipRest};--clip-hover:${clipHover};clip-path:var(--clip-rest);`;
        if (item.kind === "empty") return <div style={itemStyle} aria-hidden="true" />;
        if (item.kind === "decorative") return (
          <div class="collage__deco" style={itemStyle} data-deco-imgs={JSON.stringify((decoBySlot[item.decoSlot] ?? []).slice(1).map(img => img.src))}>
            <div class="collage__item-img collage__item-img--deco" style={imgStyle}>
              <Image src={item.img} alt="" width={600} height={900} loading="lazy" style={`padding: ${borderPadding};`} />
            </div>
          </div>
        );
        const { entry, kind } = item;
        const productSlug = getProductSlug(entry.id);
        const href = withBase(kind === "jewelry" ? `/smycken/${productSlug}` : `/stickning/${productSlug}`);
        return (
          <a class:list={["collage__item", `collage__item--${kind}`]} href={href} style={itemStyle} aria-label={`View ${entry.data.title}`}>
            <div class="collage__item-img collage__item-img--bordered" style={imgStyle} transition:name={`product-${productSlug}`}>
              <Image src={entry.data.images[0]} alt={entry.data.title} loading="lazy" width={600} height={600} style={`padding: ${borderPadding};`} />
            </div>
            <div class="collage__item-overlay" style={overlayStyle(si)} aria-hidden="true">
              <h2 class="collage__item-title" transition:name={`product-title-${productSlug}`} transition:animate="none">{entry.data.title}</h2>
              <span class="collage__item-meta">{fmt(entry.data.price)} kr</span>
            </div>
          </a>
        );
      })}
    </section>

    <!-- Endeavours -->
    {(() => {
      const e0inset   = insets[0];
      const e0offsets = cornerOffsets[0];
      const e1inset   = insets[3];
      const e1offsets = cornerOffsets[3];
      const e0clip    = `polygon(${makeClip(e0inset, e0offsets)})`;
      const e1clip    = `polygon(${makeClip(e1inset, e1offsets)})`;
      return (
        <section class="endeavours" aria-label="Endeavours">
            <div class="endeavour">
            <div class="collage__item-img collage__item-img--bordered gaza-media" style={`clip-path:${e0clip};`}>
              <Image class="gaza-media__poster" src={gazaPoster} alt="Gaza-halsbandet" loading="lazy" width={600} height={750} />
              <button class="gaza-media__play" type="button" aria-label="Spela Gaza-video"></button>
              <video
                class="gaza-media__video"
                data-src={gazaVideo}
                poster={gazaPoster.src}
                aria-label="Gaza-halsbandet"
                playsinline
                controls
                preload="metadata"
              ></video>
            </div>
            <div class="endeavour__text">
              <h2 class="collage__item-title">Gaza</h2>
              <p class="endeavour__body">Ett halsband graverat på återvunnet sterling silver, skapat i samarbete med <a class="endeavour__inline-link" href="https://www.instagram.com/vtelegin" target="_blank" rel="noopener noreferrer">Viktor Telegin</a>. 20 exemplar — alla intäkter gick till Rädda Barnen och deras arbete för barn i Gaza. <a class="endeavour__reel" href={gazaReelUrl} target="_blank" rel="noopener noreferrer">Se reel</a></p>
            </div>
          </div>
          <div class="endeavour endeavour--reversed">
            <div class="endeavour__text">
              <h2 class="collage__item-title">Typ Ett</h2>
              <p class="endeavour__body">En tunn ring med en knut högst upp, designad exklusivt för <a class="endeavour__inline-link" href="https://webbshop.barndiabetesfonden.se/produkter/knut-ring-silver" target="_blank" rel="noopener noreferrer">Barndiabetesfonden</a>. Alla intäkter går till forskning om typ 1 diabetes — ett projekt som ligger mig varmt om hjärtat som förälder till ett barn med diabetes.</p>
            </div>
            <div class="collage__item-img" style={`clip-path:${e1clip};`}
              data-cycle-imgs={JSON.stringify([d1handImg.src, typ1Img.src])}>
              <img src={d1handImg.src} alt="D1-ringen" loading="lazy" width={600} height={750} />
            </div>
          </div>
        </section>
      );
    })()}

    <section class="collage collage--final" aria-label="Works — part 2">
      {gridC.map((item, i) => {
        const si            = i + 9;
        const slot          = slots[si % slots.length];
        const inset         = insets[si % insets.length];
        const offsets       = cornerOffsets[si % cornerOffsets.length];
        const clipRest      = `polygon(${makeClip(inset, offsets)})`;
        const clipHover     = `polygon(${makeClipHover(inset, offsets)})`;
        const borderPadding = borderPaddings[si % borderPaddings.length];
        const itemStyle     = `grid-column: span ${item.span}; margin-top: ${slot.nudge};`;
        const imgStyle      = `--clip-rest:${clipRest};--clip-hover:${clipHover};clip-path:var(--clip-rest);`;
        if (item.kind === "empty") return <div style={itemStyle} aria-hidden="true" />;
        if (item.kind === "decorative") return (
          <div class="collage__deco" style={itemStyle} data-deco-imgs={JSON.stringify((decoBySlot[item.decoSlot] ?? []).slice(1).map(img => img.src))}>
            <div class="collage__item-img collage__item-img--deco" style={imgStyle}>
              <Image src={item.img} alt="" width={600} height={900} loading="lazy" style={`padding: ${borderPadding};`} />
            </div>
          </div>
        );
        const { entry, kind } = item;
        const productSlug = getProductSlug(entry.id);
        const href = withBase(kind === "jewelry" ? `/smycken/${productSlug}` : `/stickning/${productSlug}`);
        return (
          <a class:list={["collage__item", `collage__item--${kind}`, { "collage__item--mobile-hidden": i === 2 }]} href={href} style={itemStyle} aria-label={`View ${entry.data.title}`}>
            <div class="collage__item-img collage__item-img--bordered" style={imgStyle} transition:name={`product-${productSlug}`}>
              <Image src={entry.data.images[0]} alt={entry.data.title} loading="lazy" width={600} height={600} style={`padding: ${borderPadding};`} />
            </div>
            <div class="collage__item-overlay" style={overlayStyle(si)} aria-hidden="true">
              <h2 class="collage__item-title" transition:name={`product-title-${productSlug}`} transition:animate="none">{entry.data.title}</h2>
              <span class="collage__item-meta">{fmt(entry.data.price)} kr</span>
            </div>
          </a>
        );
      })}
    </section>

  </div>

</BaseLayout>

<style>
  /* ── Page wrapper ── */
  .page-flow {
    display: flex;
    flex-direction: column;
    gap: var(--space-5xl);
  }

  /* ── Collage grid ── */
  .collage {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: var(--grid-gutter);
    row-gap: var(--space-4xl);
    padding: 0 var(--layout-gutter);
    max-width: var(--layout-site-width);
    margin: 0 auto;
    align-items: start;
    width: 100%;
    box-sizing: border-box;
  }

  /* ── Shared interlude shell ── */
  .interlude {
    width: 100%;
    max-width: var(--layout-site-width);
    margin: 0 auto;
    padding: 0 var(--layout-gutter);
    box-sizing: border-box;
  }

  /* ── About interlude ── */
  .interlude--about {
    padding: var(--space-4xl) var(--layout-gutter);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
    background-color: var(--color-bg-muted);
    position: relative;
    overflow: visible;
  }

  .about__photo-wrap {
    position: absolute;
    top: calc(var(--space-4xl) * -0.75);
    left: var(--layout-gutter);
    width: clamp(180px, 28%, 300px);
    z-index: 0;
    transform: rotate(-2.5deg);
    transform-origin: top left;
  }

  .about__photo {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    object-position: top center;
  }

  .about__headline {
    font-family: var(--font-heading-text);
    font-size: clamp(3.5rem, calc(3rem + 2.8vw), 5.5rem);
    font-weight: var(--font-weight-light);
    line-height: var(--font-leading-tight);
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0;
    position: relative;
    z-index: 1;
    padding-left: clamp(155px, 24%, 265px);
  }

  .about__body {
    font-family: var(--font-body-text);
    font-size: var(--font-size-base);
    color: var(--endeavours-text);
    position: relative;
    z-index: 1;
    line-height: var(--font-leading-snug);
    margin: 0;
  }

  .about__socials {
    list-style: none;
    margin: 0;
    padding: var(--space-8) 0 0;
    display: flex;
    gap: var(--space-6);
    position: relative;
    z-index: 1;
  }

  /* ── About: mobile ── */
  @media (max-width: 760px) {
    .about__photo-wrap {
      width: clamp(90px, 26%, 160px);
      top: calc(var(--space-4xl) * -0.3);
    }

    .about__headline {
      padding-left: clamp(70px, 20%, 130px);
    }
  }

  .about__inline-link {
    color: var(--endeavours-text);
    text-decoration: underline;
    text-underline-offset: var(--underline-offset);
  }

  .about__inline-link:hover {
    opacity: 0.75;
  }

  .about__socials a {
    display: flex;
    align-items: center;
    color: var(--endeavours-text);
    text-decoration: none;
    position: relative;
    transition: opacity var(--transition-fast);
    padding: 5px;
    margin: -5px;
  }

  .about__socials a:hover {
    opacity: 0.7;
  }

  @media (hover: hover) {
    .about__socials a::after {
      content: attr(data-label);
      position: absolute;
      top: calc(100% + var(--space-2));
      left: 0;
      transform: translateY(-4px);
      font-family: var(--font-body-text);
      font-size: var(--font-size-xs);
      letter-spacing: var(--font-tracking-wide);
      white-space: nowrap;
      color: var(--endeavours-text);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--transition-fast), transform var(--transition-fast);
    }

    .about__socials a:hover::after {
      opacity: 0.7;
      transform: translateY(0);
    }

  }

  .about__socials :global(svg) {
    width: 30px;
    height: 30px;
    fill: currentColor;
    display: block;
  }

  /* ── Endeavours ── */
  .endeavours {
    display: flex;
    flex-direction: column;
    gap: var(--space-48);
    max-width: var(--layout-site-width);
    margin: 0 auto;
    padding: var(--space-4xl) var(--layout-gutter);
