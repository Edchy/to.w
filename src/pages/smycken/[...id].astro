---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductDetail from "../../components/ProductDetail.astro";
import { getCollection } from "astro:content";
import { getProductSlug } from "../../config/site";

export async function getStaticPaths() {
  const items = await getCollection("jewelry");
  return items.map((item) => ({ params: { id: getProductSlug(item.id) }, props: { entry: item } }));
}

const { entry } = Astro.props;

const { title, description } = entry.data;
const productSlug = getProductSlug(entry.id);
---

<BaseLayout title={title} description={description} noPadding>
  <ProductDetail {...entry.data} transitionName={`product-${productSlug}`} />
</BaseLayout>
