---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductDetail from "../../components/ProductDetail.astro";
import { getCollection } from "astro:content";
import { getProductSlug } from "../../config/site";

export async function getStaticPaths() {
  const items = await getCollection("knitting");
  return items.map((item) => ({ params: { id: getProductSlug(item.id) }, props: { entry: item } }));
}

const { entry } = Astro.props;

const { title, description, material, technique, design } = entry.data;
const productSlug = getProductSlug(entry.id);
const metaDescription =
  description ??
  [title, material, technique, design, "Stickat plagg eller objekt av Tove Wätte."]
    .filter(Boolean)
    .join(" ");
---

<BaseLayout title={title} description={metaDescription} noPadding>
  <ProductDetail {...entry.data} transitionName={`product-${productSlug}`} />
</BaseLayout>
