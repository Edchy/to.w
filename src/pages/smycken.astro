---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { getProductSlug } from "../config/site";

const allJewelry = await getCollection("jewelry");
const jewelry = allJewelry.sort((a, b) => b.data.date.localeCompare(a.data.date));

const fmt = new Intl.NumberFormat("sv-SE").format;
const baseUrl = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/`;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;

const insets: [number, number, number, number][] = [
  [3.5, 2.8, 4.2, 3.1],
  [4.1, 2.6, 3.0, 4.4],
  [3.8, 3.2, 2.7, 3.5],
  [2.4, 4.0, 3.7, 2.8],
  [3.0, 3.5, 4.3, 2.6],
  [4.5, 2.9, 3.2, 3.8],
  [2.6, 3.7, 4.0, 2.9],
  [3.6, 2.7, 3.3, 4.2],
];

const cornerOffsets: [number,number,number,number,number,number,number,number][] = [
  [ 0.3, 0.2,-0.2, 0.4, 0.1,-0.3,-0.4, 0.1],
  [-0.2, 0.3, 0.4,-0.1,-0.3, 0.2, 0.2,-0.4],
  [ 0.1,-0.4, 0.3, 0.2,-0.2, 0.4,-0.3,-0.1],
  [-0.3, 0.1,-0.1, 0.4, 0.4,-0.2, 0.2, 0.3],
  [ 0.4,-0.2, 0.1, 0.3,-0.4, 0.1, 0.3,-0.3],
  [-0.1, 0.4,-0.3,-0.2, 0.2, 0.3,-0.4, 0.1],
  [ 0.2, 0.3, 0.4,-0.3,-0.1, 0.2, 0.3,-0.4],
  [-0.4, 0.1, 0.2, 0.4, 0.3,-0.1,-0.2, 0.3],
];

const nudges = ["0px", "16px", "6px", "20px", "4px", "12px", "24px", "8px"];

function makeClip(
  [top, right, bottom, left]: [number, number, number, number],
  [o0, o1, o2, o3, o4, o5, o6, o7]: [number,number,number,number,number,number,number,number]
): string {
  const t = top, r = 100 - right, b = 100 - bottom, l = left;
  return [`${l+o0}% ${t+o1}%`, `${r+o2}% ${t+o3}%`, `${r+o4}% ${b+o5}%`, `${l+o6}% ${b+o7}%`].join(", ");
}

function makeClipHover(
  [top, right, bottom, left]: [number, number, number, number],
  [o0, o1, o2, o3, o4, o5, o6, o7]: [number,number,number,number,number,number,number,number]
): string {
  const f = 0.35;
  const t = top*f, r = 100 - right*f, b = 100 - bottom*f, l = left*f;
  return [`${l+o0*f}% ${t+o1*f}%`, `${r+o2*f}% ${t+o3*f}%`, `${r+o4*f}% ${b+o5*f}%`, `${l+o6*f}% ${b+o7*f}%`].join(", ");
}
---

<BaseLayout title="Smycken" description="Handgjorda smycken av Tove Wätte.">
  <div class="listing">
    <h1 class="sr-only">Smycken</h1>

    <ul class="grid" role="list">
      {jewelry.map((entry, i) => {
        const inset   = insets[i % insets.length];
        const offsets = cornerOffsets[i % cornerOffsets.length];
        const clip      = `polygon(${makeClip(inset, offsets)})`;
        const clipHover = `polygon(${makeClipHover(inset, offsets)})`;
        const nudge   = nudges[i % nudges.length];
        const productSlug = getProductSlug(entry.id);
        const href    = withBase(`/smycken/${productSlug}`);
        return (
          <li class="grid__cell" style={`--card-nudge:${nudge}`}>
            <a class="card" href={href} aria-label={`${entry.data.title} — ${fmt(entry.data.price)} kr`}>
              <div class="card__img" style={`--clip-rest:${clip};--clip-hover:${clipHover};`} transition:name={`product-${productSlug}`}>
                <Image
                  src={entry.data.images[0]}
                  alt={entry.data.title}
                  width={600}
                  height={600}
                  loading={i < 3 ? "eager" : "lazy"}
                  fetchpriority={i === 0 ? "high" : "auto"}
                />
              </div>
              <div class="card__info" aria-hidden="true">
                <span class="card__meta">{fmt(entry.data.price)} kr</span>
                <span class="card__name" transition:name={`product-title-${productSlug}`} transition:animate="none">{entry.data.title}</span>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</BaseLayout>

<style>
  .listing {
    max-width: var(--layout-site-width);
    margin: 0 auto;
    padding: var(--space-8) var(--layout-gutter) var(--space-3xl);
    box-sizing: border-box;
  }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: clamp(var(--space-3), 1.5vw, var(--space-5));
    row-gap: var(--space-3xl);
    align-items: start;
  }

  .grid__cell {
    margin-top: var(--card-nudge, 0px);
    align-self: start;
  }

  .card {
    display: block;
    text-decoration: none;
    position: relative;
    transition: scale var(--duration-fast) var(--ease-out-quart);
  }

  .card:active {
    scale: 0.96;
  }

  .card__img {
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-accent-subtle);
    position: relative;
    transition: clip-path var(--duration-normal) var(--ease-out-expo);
    clip-path: var(--clip-rest);
  }

  @media (hover: hover) {
    .card__img {
      will-change: clip-path;
    }

    .card:hover .card__img {
      clip-path: var(--clip-hover);
    }

    .card:hover .card__name {
      color: var(--color-brand);
    }

    .card:hover .card__meta {
      color: var(--color-accent-dark);
    }
  }

  .card__img::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--color-bg-base) 0%, transparent 40%);
    pointer-events: none;
    z-index: 1;
  }

  .card__img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    box-sizing: border-box;
    outline: 1px solid color-mix(in oklch, var(--color-bg-inverse) 6%, transparent);
    outline-offset: -1px;
  }

  .card__info {
    margin-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .card__name {
    font-family: var(--font-heading-text);
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-regular);
    line-height: var(--font-leading-tight);
    color: var(--color-text-primary);
    letter-spacing: var(--font-tracking-tightest);
    transition: color var(--transition-fast);
  }

  .card__meta {
    font-family: var(--font-body-text);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--font-tracking-wider);
    text-transform: uppercase;
    color: var(--color-brand);
    transition: color var(--transition-fast);
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      row-gap: var(--space-16);
    }

    .grid__cell {
      --card-nudge: 0px;
    }
  }
</style>
