---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { getProductSlug } from "../config/site";

const allJewelry = await getCollection("jewelry");
const jewelry = allJewelry.sort((a, b) => b.data.date.localeCompare(a.data.date));

const fmt = new Intl.NumberFormat("sv-SE").format;
const baseUrl = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/`;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;
const jewelryRows = [
  jewelry.slice(0, 2),
  jewelry.slice(2, 4),
  jewelry.slice(4, 6),
  jewelry.slice(6, 8),
].filter((row) => row.length > 0);
const captionSideBySlug: Record<string, "left" | "right"> = {
  bark: "left",
  frost: "left",
  golden: "left",
};
---

<BaseLayout title="Smycken" description="Handgjorda smycken av Tove Wätte.">
  <div class="listing">
    <h1 class="sr-only">Smycken</h1>

    {jewelryRows.map((row, rowIndex) => (
      <section class:list={["work", `work--row-${rowIndex + 1}`]} aria-label={`Smycken rad ${rowIndex + 1}`}>
        {row.map((entry, i) => {
          const globalIndex = rowIndex * 2 + i;
          const productSlug = getProductSlug(entry.id);
          const captionSide = captionSideBySlug[productSlug];
          const href = withBase(`/smycken/${productSlug}`);
          return (
            <a
              class:list={[
                "work-card",
                captionSide && "work-card--caption-side",
                captionSide && `work-card--caption-${captionSide}`,
              ]}
              href={href}
              aria-label={`Visa ${entry.data.title}`}
            >
              <figure class="work-card__figure">
                <div class="work-card__media" transition:name={`product-${productSlug}`}>
                  <Image
                    src={entry.data.images[0]}
                    alt={entry.data.title}
                    width={720}
                    height={900}
                    loading={globalIndex < 4 ? "eager" : "lazy"}
                    fetchpriority={globalIndex === 0 ? "high" : "auto"}
                  />
                </div>
                <figcaption class="work-card__caption">
                  <h2 class="work-card__title" transition:name={`product-title-${productSlug}`} transition:animate="none">{entry.data.title}</h2>
                  <span class="work-card__price">{fmt(entry.data.price)} kr</span>
                  {entry.data.description && (
                    <p class="work-card__description">{entry.data.description}</p>
                  )}
                </figcaption>
              </figure>
            </a>
          );
        })}
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .listing {
    max-width: var(--layout-wide-width);
    margin: 0 auto;
    padding: var(--space-8) var(--layout-gutter) var(--space-24);
    box-sizing: border-box;
  }

  .work {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: clamp(var(--space-4), 2.2vw, var(--space-10));
    row-gap: clamp(var(--space-24), 12vw, var(--space-72));
    align-items: start;
  }

  .work + .work {
    margin-top: clamp(var(--space-24), 12vw, var(--space-72));
  }

  .work-card {
    --work-frame: var(--color-bg-muted);
    --work-frame-hover: var(--color-accent-subtle);
    --work-tilt: -1.5deg;
    --caption-default-width: min(56ch, calc(100vw - (var(--layout-gutter) * 2)));
    --caption-width: var(--caption-default-width);
    grid-column: span 3;
    display: block;
    color: var(--color-text-primary);
  }

  .work-card:nth-child(6n + 1) {
    --work-frame: var(--color-accent-subtle);
    --work-frame-hover: var(--color-bg-muted);
    --work-tilt: 1.4deg;
    grid-column: 1 / span 4;
  }

  .work-card:nth-child(6n + 2) {
    --work-frame: var(--color-brand-subtle);
    --work-frame-hover: var(--color-accent-subtle);
    --work-tilt: -2.2deg;
    grid-column: 8 / span 3;
    margin-top: var(--space-20);
  }

  .work--row-2 .work-card:nth-child(1) {
    grid-column: 2 / span 3;
    margin-top: var(--space-12);
  }

  .work--row-2 .work-card:nth-child(2) {
    grid-column: 8 / span 4;
    margin-top: var(--space-20);
  }

  .work--row-3 .work-card:nth-child(1) {
    grid-column: 1 / span 4;
    margin-top: var(--space-16);
  }

  .work--row-3 .work-card:nth-child(2) {
    grid-column: 7 / span 4;
  }

  .work--row-4 .work-card:nth-child(1) {
    grid-column: 3 / span 3;
  }

  .work--row-4 .work-card:nth-child(2) {
    grid-column: 8 / span 3;
    margin-top: var(--space-20);
  }

  .work-card__figure {
    margin: 0;
    display: grid;
    gap: 0;
    position: relative;
  }

  .work-card__media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--work-frame);
    border: var(--space-2) solid var(--work-frame);
    border-bottom-width: var(--space-4);
    border-radius: var(--radius-sm);
    padding: var(--space-2);
    box-shadow: 0 var(--space-2) 0 color-mix(in oklch, var(--color-text-primary) 8%, transparent);
    transform-origin: 50% 62%;
    position: relative;
    z-index: 1;
    transition:
      background-color var(--transition-slow),
      border-color var(--transition-slow),
      box-shadow var(--transition-slow),
      filter var(--transition-normal),
      transform var(--transition-slow);
  }

  .work-card__media::after {
    content: "";
    position: absolute;
    inset: var(--space-2);
    border: 1px solid color-mix(in oklch, var(--color-text-primary) 9%, transparent);
    border-radius: var(--radius-sm);
    opacity: 0.7;
    pointer-events: none;
    transition:
      opacity var(--transition-normal),
      transform var(--transition-slow);
  }

  .work-card__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    border-radius: var(--radius-sm);
    transition:
      filter var(--transition-slow),
      transform var(--transition-slow);
  }

  .work-card__caption {
    display: grid;
    gap: var(--space-1);
    position: relative;
    z-index: 2;
    padding-top: 0;
    margin-top: calc(var(--space-8) * -1);
    transform: translateX(calc(var(--space-3) * -1));
    transition: transform var(--transition-slow);
  }

  .work-card--caption-side {
    --caption-width: min(30ch, calc(100vw - (var(--layout-gutter) * 2)));
  }

  .work-card--caption-side .work-card__caption {
    position: absolute;
    top: 50%;
    width: var(--caption-width);
    margin-top: 0;
    transform: translateY(-50%);
  }

  .work-card--caption-right .work-card__caption {
    left: calc(100% - var(--space-8));
  }

  .work-card--caption-left .work-card__caption {
    right: calc(100% - var(--space-8));
    justify-items: end;
    text-align: right;
  }

  .work-card__title {
    width: fit-content;
    max-width: 8ch;
    font-size: clamp(2.1rem, 4.2vw, 5.4rem);
    font-weight: var(--font-weight-regular);
    line-height: 0.9;
    letter-spacing: var(--font-tracking-tightest);
    position: relative;
  }

  .work-card__title::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.12em;
    height: 1px;
    background: currentColor;
    opacity: 0;
    transform: scaleX(0.35);
    transform-origin: left;
    transition:
      opacity var(--transition-normal),
      transform var(--transition-slow);
  }

  .work-card__price {
    width: fit-content;
    padding: var(--space-1) var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    letter-spacing: var(--font-tracking-wide);
    font-variant-numeric: tabular-nums;
    transition:
      color var(--transition-normal),
      opacity var(--transition-normal),
      transform var(--transition-normal);
  }

  .work-card__description {
    width: var(--caption-width);
    margin: var(--space-2) 0 0;
    font-size: var(--font-size-sm);
    line-height: var(--font-leading-snug);
    color: var(--color-text-secondary);
    text-wrap: pretty;
    transition:
      color var(--transition-normal),
      transform var(--transition-slow);
  }

  @media (hover: hover) {
    .work-card:hover .work-card__media {
      background-color: var(--work-frame-hover);
      border-color: var(--work-frame-hover);
      box-shadow: var(--space-2) var(--space-3) 0 color-mix(in oklch, var(--color-text-primary) 13%, transparent);
      filter: saturate(1.02);
      transform: translateY(calc(var(--space-2) * -1)) rotate(var(--work-tilt)) scale(1.025);
    }

    .work-card:hover .work-card__media::after {
      opacity: 0.25;
      transform: scale(0.96);
    }

    .work-card:hover .work-card__media img {
      filter: contrast(1.02) saturate(0.95);
      transform: scale(1.055) rotate(calc(var(--work-tilt) * -0.7));
    }

    .work-card:hover .work-card__caption {
      transform: translate(calc(var(--space-1) * -1), calc(var(--space-2) * -1));
    }

    .work-card--caption-side:hover .work-card__caption {
      transform: translate(calc(var(--space-1) * -1), calc(-50% - var(--space-2)));
    }

    .work-card:hover .work-card__title::after {
      opacity: 0.55;
      transform: scaleX(1);
    }

    .work-card:hover .work-card__price,
    .work-card:hover .work-card__description {
      color: var(--color-text-primary);
      transform: translateX(var(--space-1));
    }

    .work-card--caption-left:hover .work-card__description,
    .work-card--caption-left:hover .work-card__price {
      transform: translateX(calc(var(--space-1) * -1));
    }
  }

  @media (max-width: 920px) {
    .listing {
      padding-top: var(--space-6);
    }

    .work {
      grid-template-columns: repeat(6, minmax(0, 1fr));
      row-gap: var(--space-32);
    }

    .work-card,
    .work-card:nth-child(n),
    .work.work--row-2 .work-card:nth-child(n),
    .work.work--row-3 .work-card:nth-child(n),
    .work.work--row-4 .work-card:nth-child(n) {
      grid-column: span 3;
      margin-top: 0;
    }

    .work-card:nth-child(4n + 2),
    .work-card:nth-child(4n + 3) {
      margin-top: var(--space-16);
    }

    .work-card--caption-side .work-card__caption {
      position: relative;
      top: auto;
      right: auto;
      left: auto;
      width: auto;
      margin-top: calc(var(--space-8) * -1);
      transform: translateX(calc(var(--space-3) * -1));
      justify-items: start;
      text-align: left;
    }

    .work-card--caption-side .work-card__description {
      --caption-width: var(--caption-default-width);
    }
  }

  @media (max-width: 560px) {
    .listing {
      padding-bottom: var(--space-16);
    }

    .work {
      grid-template-columns: repeat(2, 1fr);
      column-gap: var(--space-3);
      row-gap: var(--space-20);
    }

    .work-card,
    .work-card:nth-child(n),
    .work.work--row-2 .work-card:nth-child(n),
    .work.work--row-3 .work-card:nth-child(n),
    .work.work--row-4 .work-card:nth-child(n) {
      --caption-default-width: min(40ch, calc(100vw - (var(--layout-gutter) * 2)));
      grid-column: span 1;
      margin-top: 0;
    }

    .work-card:nth-child(even) {
      margin-top: var(--space-10);
    }

    .work-card__title,
    .work-card:nth-child(n) .work-card__title {
      font-size: var(--font-size-xl);
      max-width: 9ch;
    }

    .work-card__price,
    .work-card__description {
      font-size: var(--font-size-xs);
    }
  }
</style>
