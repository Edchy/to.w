---
import "../styles/global.css";
import { Font } from "astro:assets";

type Props = {
  title?: string;
  description?: string;
};

const { title, description = "to.w — handmade jewelry and objects." } = Astro.props;
const pageTitle = title ? `${title} — to.w` : "to.w";
const baseUrl = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/`;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;

const navLinks = [
  { href: "/stickning", label: "knitting" },
  { href: "/smycken", label: "jewelry" },

];

const basePath = new URL(baseUrl, "https://example.com").pathname.replace(/\/$/, "");
const currentPath = Astro.url.pathname.replace(basePath, "") || "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <title>{pageTitle}</title>
    <Font cssVariable="--font-body" />
    <Font cssVariable="--font-june-active" />
    <Font cssVariable="--font-june-curious" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-wrap site-header__inner">
        <a href={baseUrl} class="site-logo" aria-label="to.w — home">to.w</a>
        <nav aria-label="Main navigation">
          <ul class="nav-list" role="list">
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={withBase(href)}
                  class:list={["nav-link", { "nav-link--active": currentPath === href || (href !== "/" && currentPath.startsWith(href)) }]}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-wrap site-footer__inner">
        <a href={baseUrl} class="footer-wordmark" aria-label="to.w — home">to.w</a>
        <ul class="footer-links" role="list">
          <li><a href="https://instagram.com/tow.studio" target="_blank" rel="noopener noreferrer">instagram</a></li>
          <li><a href="mailto:hello@tow.studio">hello@tow.studio</a></li>
        </ul>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-wrap {
    width: 100%;
    max-width: var(--layout-site-width);
    margin-inline: auto;
    padding-inline: var(--layout-gutter);
  }

  .site-header {
    position: relative;
    height: var(--nav-height);
    background-color: color-mix(in oklch, var(--color-bg-base) 92%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .site-logo {
    font-family: var(--brand-font-active);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--font-tracking-wide);
    color: var(--color-brand);
    line-height: 1;
  }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-8);
  }

  .nav-link {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--font-tracking-wide);
    text-transform: lowercase;
    color: var(--color-brand);
    transition: color var(--transition-fast), opacity var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-accent-dark);
    opacity: 0.7;
  }

  .nav-link--active {
    color: var(--color-brand);
    text-decoration: none;
    position: relative;
  }

  .nav-link--active::after {
    content: '';
    position: absolute;
    left: -1px;
    right: -2px;
    bottom: -4px;
    height: 3px;
    background: var(--color-brand);
    border-radius: 1px;
    transform: rotate(-1.5deg);
    transform-origin: left center;
  }

  main {
    padding-top: var(--nav-height);
    min-height: 100svh;
  }

  /* ── Footer ── */

  .site-footer {
    padding-top: var(--space-5xl);
    padding-bottom: var(--space-12);
  }

  .site-footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .footer-wordmark {
    font-family: var(--brand-font-active);
    font-size: var(--font-size-lg);
    color: var(--color-brand);
    letter-spacing: var(--font-tracking-wide);
    line-height: 1;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .footer-links a {
    font-size: var(--font-size-sm);
    color: var(--color-brand);
    letter-spacing: var(--font-tracking-wide);
    text-transform: lowercase;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-accent-dark);
  }
</style>
