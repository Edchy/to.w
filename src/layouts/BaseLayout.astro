---
import "../styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import { CONTACT_EMAIL, CONTACT_EMAIL_HREF } from "../config/site";

type Props = {
  title?: string;
  description?: string;
  noPadding?: boolean;
};

const { title, description = "to.w — handmade jewelry and objects.", noPadding = false } = Astro.props;
const pageTitle = title ? `${title} — to.w` : "to.w";
const baseUrl = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/`;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: "/stickning", label: "knitting" },
  { href: "/smycken", label: "jewelry" },

];

const basePath = new URL(baseUrl, "https://example.com").pathname.replace(/\/$/, "");
const currentPath = Astro.url.pathname.replace(basePath, "") || "/";
---

<!doctype html>
<html lang="en" data-theme="a">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <title>{pageTitle}</title>
    <Font cssVariable="--font-body" />
    <Font cssVariable="--font-june-active" />
    <Font cssVariable="--font-june-curious" />
    <ClientRouter />
  </head>
  <body>
    <div class="shop-banner" role="note" aria-live="polite" transition:persist>
      <p class="shop-banner__full">
        the webshop is under reconstruction — you can still order by <a href={CONTACT_EMAIL_HREF}>mailing</a> and paying via swish.
      </p>
      <div class="shop-banner__carousel" aria-hidden="true">
        <span class="shop-banner__track">
          <span class="shop-banner__item">the webshop is under reconstruction — order by <a href={CONTACT_EMAIL_HREF}>mailing</a> and pay via swish</span>
          <span class="shop-banner__sep" aria-hidden="true">·</span>
          <span class="shop-banner__item">the webshop is under reconstruction — order by <a href={CONTACT_EMAIL_HREF}>mailing</a> and pay via swish</span>
          <span class="shop-banner__sep" aria-hidden="true">·</span>
        </span>
      </div>
    </div>

    <header class="site-header">
      <div class="site-wrap site-header__inner">
        <a href={baseUrl} class="site-logo" aria-label="to.w — home">to.w</a>
        <nav aria-label="Main navigation">
          <ul class="nav-list" role="list">
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={withBase(href)}
                  class:list={["nav-link", { "nav-link--active": currentPath === href || (href !== "/" && currentPath.startsWith(href)) }]}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main class:list={[{ "main--no-padding": noPadding }]}>
      <slot />
    </main>

    <div class="theme-picker" role="group" aria-label="Theme" transition:persist>
      <button data-theme-btn="a">A</button>
      <button data-theme-btn="b">B</button>
      <button data-theme-btn="c">C</button>
      <button data-theme-btn="d">D</button>
    </div>

    <footer class:list={["site-footer", { "site-footer--hidden": noPadding }]}>
      <div class="site-wrap site-footer__inner">
        <div class="footer-brand">
          <a href={baseUrl} class="footer-wordmark" aria-label="to.w — home">to.w</a>
          <ul class="footer-socials footer-socials--mobile" role="list">
            <li>
              <a href="https://instagram.com/tovewatte" target="_blank" rel="noopener noreferrer">Instagram</a>
            </li>
            <li>
              <a href={CONTACT_EMAIL_HREF}>{CONTACT_EMAIL}</a>
            </li>
          </ul>
        </div>
        <div class="footer-directory">
          <nav class="footer-group" aria-label="Footer navigation">
            <ul class="footer-links" role="list">
              {navLinks.map(({ href, label }) => (
                <li>
                  <a
                    href={withBase(href)}
                    class:list={["footer-link", { "footer-link--active": currentPath === href || (href !== "/" && currentPath.startsWith(href)) }]}
                  >
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
          <div class="footer-group">
            <ul class="footer-socials" role="list">
              <li>
                <a href="https://instagram.com/tovewatte" target="_blank" rel="noopener noreferrer">Instagram</a>
              </li>
              <li>
                <a href={CONTACT_EMAIL_HREF}>{CONTACT_EMAIL}</a>
              </li>
            </ul>
          </div>
        </div>
        <div class="footer-colophon">
          <p>&copy; {currentYear} to.w</p>
          <p>
            website by
            <a href="https://nope.digital" target="_blank" rel="noopener noreferrer">nope digital</a>
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-wrap {
    width: 100%;
    max-width: var(--layout-site-width);
    margin-inline: auto;
    padding-inline: var(--layout-gutter);
  }

  .site-header {
    position: relative;
    height: var(--nav-height);
    background-color: color-mix(in oklch, var(--color-bg-base) 92%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .site-logo {
    font-family: var(--font-brand-text);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--font-tracking-wide);
    color: var(--color-brand);
    line-height: 1;
  }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-8);
  }

  .nav-link {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--font-tracking-wide);
    text-transform: lowercase;
    color: var(--color-brand);
    transition: color var(--transition-fast), opacity var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-accent-dark);
    opacity: 0.7;
  }

  .nav-link--active {
    color: var(--color-brand);
    text-decoration: none;
    position: relative;
  }

  .nav-link--active::after {
    content: '';
    position: absolute;
    left: -1px;
    right: -2px;
    bottom: -4px;
    height: 1.5px;
    background: var(--color-brand);
    border-radius: 1px;
    transform: rotate(-1.5deg);
    transform-origin: left center;
  }

  .shop-banner {
    position: relative;
    z-index: var(--z-raised);
    background: var(--color-accent-subtle);
    text-align: center;
    padding: var(--space-1) 0;
  }

  .shop-banner p,
  .shop-banner__slide {
    font-size: var(--font-size-sm);
    color: var(--color-text-primary);
    letter-spacing: var(--font-tracking-wide);
    margin: 0;
  }

  .shop-banner a {
    color: var(--color-brand);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .shop-banner a:hover {
    color: var(--color-accent-dark);
  }

  .shop-banner__carousel {
    display: none;
    overflow: hidden;
  }

  .shop-banner__track {
    display: inline-flex;
    align-items: center;
    gap: var(--space-6);
    white-space: nowrap;
    animation: banner-scroll 18s linear infinite;
  }

  .shop-banner__item,
  .shop-banner__sep {
    font-size: var(--font-size-sm);
    color: var(--color-text-primary);
    letter-spacing: var(--font-tracking-wide);
    flex-shrink: 0;
  }

  .shop-banner__sep {
    opacity: 0.4;
  }

  @keyframes banner-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width: 1000px) {
    .shop-banner__full {
      display: none;
    }

    .shop-banner__carousel {
      display: block;
    }
  }

  main {
    padding-top: var(--nav-height);
    flex: 1;
  }

  main.main--no-padding {
    padding-top: var(--space-6);
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 1000px) {
    main.main--no-padding {
      padding-top: 0;
    }
  }

  :global(::view-transition-old(root)),
  :global(::view-transition-new(root)) {
    animation-duration: var(--duration-slow);
    animation-timing-function: var(--ease-out-quart);
    mix-blend-mode: normal;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(::view-transition-old(root)),
    :global(::view-transition-new(root)) {
      animation: none;
    }
  }

  /* ── Footer ── */

  .site-footer--hidden {
    display: none;
  }

  .site-footer {
    margin-top: var(--space-24);
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
    background-color: var(--color-bg-muted);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    row-gap: var(--space-12);
    column-gap: var(--space-12);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .footer-wordmark {
    font-family: var(--font-brand-text);
    font-size: var(--font-size-display);
    color: var(--color-brand);
    letter-spacing: var(--font-tracking-normal);
    line-height: var(--font-leading-tight);
  }

  .footer-directory {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-8);
    padding-top: var(--space-2);
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .footer-links a {
    font-size: var(--font-size-sm);
    color: var(--color-brand);
    letter-spacing: var(--font-tracking-wide);
    text-transform: lowercase;
    transition: color var(--transition-fast), opacity var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-accent-dark);
    opacity: 0.7;
  }

  .footer-socials {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .footer-socials a {
    font-size: var(--font-size-sm);
    color: var(--color-brand);
    letter-spacing: var(--font-tracking-wide);
    text-transform: lowercase;
    transition: color var(--transition-fast), opacity var(--transition-fast);
  }

  .footer-socials a:hover {
    color: var(--color-accent-dark);
    opacity: 0.7;
  }


  .footer-link--active {
    color: var(--color-accent-dark);
    text-decoration: underline;
    text-underline-offset: var(--space-1);
  }

  .footer-colophon {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    gap: var(--space-6);
    padding-top: var(--space-6);
  }

  .footer-colophon p {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--color-brand);
    letter-spacing: var(--font-tracking-wide);
    line-height: var(--font-leading-snug);
    text-transform: lowercase;
  }

  .footer-colophon a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: var(--space-1);
    transition: color var(--transition-fast), opacity var(--transition-fast);
  }

  .footer-colophon a:hover {
    color: var(--color-accent-dark);
    opacity: 0.7;
  }

  .footer-socials--mobile {
    display: none;
  }

  @media (min-width: 761px) {
    .site-footer {
      margin-top: var(--space-72);
      padding-top: var(--space-24);
    }
  }

  @media (max-width: 760px) {
    .site-footer {
      margin-top: var(--space-48);
      background-color: transparent;
    }

    .site-footer__inner {
      grid-template-columns: 1fr;
      row-gap: var(--space-8);
    }

    .footer-directory,
    .footer-colophon {
      display: none;
    }

    .footer-socials--mobile {
      display: flex;
      flex-direction: row;
      gap: var(--space-6);
      margin-top: var(--space-4);
    }

    .footer-wordmark {
      font-size: var(--font-size-3xl);
    }
  }

  .theme-picker {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    display: flex;
    gap: var(--space-2);
    z-index: var(--z-overlay);
  }

  .theme-picker button {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    border: 1.5px solid var(--color-brand);
    background: var(--color-bg-base);
    color: var(--color-brand);
    font-size: var(--font-size-sm);
    font-family: var(--font-body-text);
    letter-spacing: var(--font-tracking-wide);
    opacity: 0.5;
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .theme-picker button:hover {
    opacity: 1;
  }

  .theme-picker button[aria-pressed="true"] {
    opacity: 1;
    background: var(--color-brand);
    color: var(--color-bg-base);
    transform: scale(1.1);
  }
</style>

<script>
  const html = document.documentElement;
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-btn]');

  function setTheme(theme: string) {
    html.dataset.theme = theme;
    buttons.forEach(btn => {
      btn.setAttribute('aria-pressed', String(btn.dataset.themeBtn === theme));
    });
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => setTheme(btn.dataset.themeBtn!));
  });

  setTheme(html.dataset.theme ?? 'a');

</script>
