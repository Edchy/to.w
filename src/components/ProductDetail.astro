---
import { Image } from "astro:assets";
import { CONTACT_EMAIL_HREF } from "../config/site";

type Props = {
  title: string;
  price: number;
  sizes: string[];
  description?: string;
  material?: string;
  technique?: string;
  design?: string;
  images: ImageMetadata[];
  transitionName?: string;
};

const { title, price, description, images, transitionName } = Astro.props;

const fmt = new Intl.NumberFormat("sv-SE").format;
const orderHref = `${CONTACT_EMAIL_HREF}?subject=${encodeURIComponent(`Beställning: ${title}`)}`;
---

<div class="pd">

  <!-- ── Left: image stage ── -->
  <div class="pd__stage" data-gallery transition:name={transitionName} aria-label={`${title} bilder`}>
    {images.map((img, i) => (
      <div class="pd__slide" data-slide aria-hidden={i !== 0}>
        <Image
          src={img}
          alt={images.length > 1 ? `${title} — bild ${i + 1}` : title}
          width={1600}
          height={1200}
          loading={i === 0 ? "eager" : "lazy"}
        />
      </div>
    ))}

    {images.length > 1 && (
      <div class="pd__thumbs" role="group" aria-label="Välj bild">
        {images.map((img, i) => (
          <button class="pd__thumb" type="button" data-thumb={i} aria-label={`Visa bild ${i + 1} av ${images.length}`} aria-pressed={i === 0}>
            <Image src={img} alt="" width={120} height={120} loading="lazy" />
          </button>
        ))}
      </div>
    )}
  </div>

  <!-- ── Right: info panel ── -->
  <div class="pd__info">

    <div class="pd__summary">
      <h1
        class="pd__title"
        transition:name={transitionName ? `${transitionName.replace("product-", "product-title-")}` : undefined}
        transition:animate="none"
      >
        {title}
      </h1>
      <span class="pd__price">{fmt(price)} kr</span>
      <a class="pd__buy" href={orderHref}>
        <span class="pd__buy-text">Beställ</span>
      </a>
    </div>

    <div class="pd__support">
      <div class="pd__body">
        {description && <p class="pd__description">{description}</p>}
      </div>
    </div>

  </div>

</div>


<style>
  /* ── Split screen wrapper ── */

  .pd {
    display: grid;
    grid-template-columns: 55fr 45fr;
    flex: 1;
    min-height: 0;
  }

  /* ── Left: image stage ── */

  .pd__stage {
    position: relative;
    overflow: hidden;
    background: var(--color-bg-muted);
    cursor: e-resize;
    user-select: none;
  }

  .pd__stage.is-left { cursor: w-resize; }

  .pd__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--duration-slow) var(--ease-out-quart);
  }

  .pd__slide:first-child { opacity: 1; }
  .pd__slide[aria-hidden="false"] { opacity: 1; }
  .pd__slide[aria-hidden="true"] { opacity: 0; }

  .pd__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    -webkit-user-drag: none;
    pointer-events: none;
    outline: 1px solid color-mix(in oklch, var(--color-bg-inverse) 8%, transparent);
    outline-offset: -1px;
  }

  /* ── Thumbnails ── */

  .pd__thumbs {
    position: absolute;
    right: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    z-index: 10;
  }

  .pd__thumb {
    width: var(--space-12);
    height: var(--space-12);
    padding: 0;
    border: 1.5px solid transparent;
    border-radius: var(--radius-sm);
    background: none;
    cursor: pointer;
    overflow: hidden;
    opacity: 0.5;
    transition: opacity var(--transition-fast), border-color var(--transition-fast);
  }

  .pd__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .pd__thumb:hover { opacity: 0.8; }

  .pd__thumb[aria-pressed="true"] {
    opacity: 1;
    border-color: var(--color-text-inverse);
  }

  /* ── Right: info panel ── */

  .pd__info {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: var(--space-12) var(--layout-gutter);
    gap: var(--space-5);
    min-height: 0;
  }

  .pd__summary,
  .pd__support {
    display: contents;
  }

  .pd__title {
    font-family: var(--font-heading-text);
    font-size: clamp(4rem, 10vw, 9rem);
    font-weight: var(--font-weight-regular);
    line-height: var(--font-leading-tight);
    letter-spacing: var(--font-tracking-tight);
    color: var(--color-brand);
    margin: 0 0 0 -0.055em;
  }

  .pd__price {
    font-family: var(--font-body-text);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--font-tracking-wide);
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }

  .pd__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .pd__description {
    font-size: var(--font-size-base);
    line-height: var(--font-leading-relaxed);
    color: var(--color-text-primary);
    margin: 0;
  }

  /* ── CTA ── */

  .pd__buy {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 100%;
    max-width: var(--space-48);
    min-height: var(--space-12);
    padding: 0 var(--space-6);
    background-color: var(--color-brand);
    border: 0;
    border-radius: var(--radius-full);
    color: var(--color-text-inverse);
    font-family: var(--font-body-text);
    font-size: var(--font-size-base);
    letter-spacing: var(--font-tracking-wide);
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition:
      background-color var(--transition-normal),
      color var(--transition-normal),
      transform var(--transition-fast);
  }

  .pd__buy:hover {
    background-color: var(--color-accent-dark);
    color: var(--color-text-inverse);
  }

  .pd__buy:active {
    transform: scale(0.96);
  }

  .pd__buy-text
   {
    position: relative;
  }


    transition: transform var(--transition-fast);


  .pd__buy:hover { transform: translate(2px, -2px); }

  /* ── Tablet ── */

  @media (max-width: 1000px) {
    .pd {
      grid-template-columns: 1fr;
      height: auto;
    }

    .pd__stage {
      height: min(48svh, 460px);
      min-height: 320px;
    }

    .pd__info {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.85fr);
      align-items: start;
      column-gap: var(--layout-gutter);
      row-gap: var(--space-5);
      max-width: var(--layout-site-width);
      width: 100%;
      margin-inline: auto;
      padding-block: var(--space-8) var(--space-12);
    }

    .pd__summary,
    .pd__support {
      display: flex;
      flex-direction: column;
    }

    .pd__summary {
      grid-column: 1;
      grid-row: 1;
      gap: var(--space-5);
    }

    .pd__support {
      grid-column: 2;
      grid-row: 1;
      gap: var(--space-5);
    }

    .pd__title {
      font-size: clamp(var(--font-size-3xl), 8vw, 6rem);
    }

  }

  /* ── Mobile ── */

  @media (max-width: 760px) {
    .pd {
      grid-template-columns: 1fr;
      height: auto;
    }

    .pd__stage {
      height: min(58svh, 480px);
      min-height: 300px;
    }

    .pd__info {
      display: flex;
      padding: var(--space-8) var(--layout-gutter) var(--space-16);
      gap: var(--space-6);
    }

    .pd__summary,
    .pd__support {
      display: flex;
      flex-direction: column;
    }

    .pd__summary {
      gap: var(--space-4);
    }

    .pd__support {
      gap: var(--space-5);
    }

    .pd__title {
      font-size: var(--font-size-3xl);
      margin-top: 0;
    }

    .pd__price {
      font-size: var(--font-size-lg);
    }

    .pd__buy {
      width: 100%;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLElement>("[data-gallery]").forEach((gallery) => {
      const slides = Array.from(gallery.querySelectorAll<HTMLElement>("[data-slide]"));
      if (slides.length < 2) return;

      const thumbs = Array.from(gallery.querySelectorAll<HTMLButtonElement>("[data-thumb]"));
      let current = 0;
      let bounds = gallery.getBoundingClientRect();

      const show = (next: number) => {
        slides[current].setAttribute("aria-hidden", "true");
        thumbs[current]?.setAttribute("aria-pressed", "false");
        current = ((next % slides.length) + slides.length) % slides.length;
        slides[current].setAttribute("aria-hidden", "false");
        thumbs[current]?.setAttribute("aria-pressed", "true");
      };

      const isLeftSide = (clientX: number) => (clientX - bounds.left) < bounds.width / 2;

      gallery.addEventListener("mouseenter", () => {
        bounds = gallery.getBoundingClientRect();
      });

      window.addEventListener("resize", () => {
        bounds = gallery.getBoundingClientRect();
      });

      gallery.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).closest("[data-thumb]")) return;
        show(isLeftSide(e.clientX) ? current - 1 : current + 1);
      });

      thumbs.forEach((btn) => {
        btn.addEventListener("click", () => show(Number(btn.dataset.thumb)));
      });

      gallery.addEventListener("mousemove", (e) => {
        if ((e.target as HTMLElement).closest("[data-thumb]")) return;
        gallery.classList.toggle("is-left", isLeftSide(e.clientX));
      });
    });
  });
</script>
