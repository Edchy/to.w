---
import { Image } from "astro:assets";
import { CONTACT_EMAIL_HREF } from "../config/site";

type Props = {
  title: string;
  price: number;
  sizes: string[];
  description?: string;
  material?: string;
  technique?: string;
  design?: string;
  images: ImageMetadata[];
  imagesHd?: ImageMetadata[];
  transitionName?: string;
};

const { title, price, description, images, imagesHd, transitionName } = Astro.props;
const stageImages = imagesHd ?? images;

const fmt = new Intl.NumberFormat("sv-SE").format;
const orderHref = `${CONTACT_EMAIL_HREF}?subject=${encodeURIComponent(`Beställning: ${title}`)}`;
---

<div class="pd">

  <!-- ── Left: image stage ── -->
  <div
    class="pd__stage"
    data-gallery
    transition:name={transitionName}
    aria-label={`${title} bilder`}
    aria-roledescription="bildgalleri"
    tabindex="0"
  >
    {stageImages.map((img, i) => (
      <div class="pd__slide" data-slide aria-hidden={i !== 0}>
        <Image
          src={img}
          alt={stageImages.length > 1 ? `${title} — bild ${i + 1}` : title}
          width={1600}
          height={1200}
          loading={i === 0 ? "eager" : "lazy"}
          fetchpriority={i === 0 ? "high" : "auto"}
        />
      </div>
    ))}

    {stageImages.length > 1 && (
      <div class="pd__thumbs" role="group" aria-label="Välj bild">
        {images.map((img, i) => (
          <button class="pd__thumb" type="button" data-thumb={i} aria-label={`Visa bild ${i + 1} av ${stageImages.length}`} aria-pressed={i === 0}>
            <Image src={img} alt="" width={120} height={120} loading="lazy" />
          </button>
        ))}
      </div>
    )}
  </div>

  <!-- ── Right: info panel ── -->
  <div class="pd__info">

    <div class="pd__summary">
      <h1
        class="pd__title"
        transition:name={transitionName ? `${transitionName.replace("product-", "product-title-")}` : undefined}
        transition:animate="none"
      >
        {title}
      </h1>
      <span class="pd__price">{fmt(price)} kr</span>
      <a class="pd__buy" href={orderHref}>
        <span class="pd__buy-text">Beställ</span>
      </a>
    </div>

    <div class="pd__support">
      <div class="pd__body">
        {description && <p class="pd__description">{description}</p>}
      </div>
    </div>

  </div>

</div>


<style>
  /* ── Split screen wrapper ── */

  .pd {
    display: grid;
    grid-template-columns: 55fr 45fr;
    flex: 1;
    min-height: 0;
  }

  /* ── Left: image stage ── */

  .pd__stage {
    position: relative;
    overflow: hidden;
    background: var(--color-bg-muted);
    cursor: e-resize;
    user-select: none;
  }

  .pd__stage.is-left { cursor: w-resize; }

  .pd__stage:focus-visible {
    outline: 1px solid var(--color-brand);
    outline-offset: -2px;
  }

  .pd__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--duration-slow) var(--ease-out-quart);
  }

  .pd__slide:first-child { opacity: 1; }
  .pd__slide[aria-hidden="false"] { opacity: 1; }
  .pd__slide[aria-hidden="true"] { opacity: 0; }

  .pd__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    -webkit-user-drag: none;
    pointer-events: none;
    outline: 1px solid color-mix(in oklch, var(--color-bg-inverse) 6%, transparent);
    outline-offset: -1px;
    transition: transform 600ms var(--ease-out-expo);
    will-change: transform;
  }

  @media (hover: hover) {
    .pd__stage:hover .pd__slide[aria-hidden="false"] img {
      transform: scale(1.03) translate(var(--parallax-x, 0px), var(--parallax-y, 0px));
    }
  }

  /* ── Thumbnails ── */

  .pd__thumbs {
    position: absolute;
    right: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    z-index: 10;
  }

  .pd__thumb {
    width: var(--space-12);
    height: var(--space-12);
    padding: 0;
    border: 1.5px solid transparent;
    border-radius: var(--radius-md);
    background: none;
    cursor: pointer;
    overflow: hidden;
    opacity: 0.5;
    transition: opacity var(--transition-fast), border-color var(--transition-fast);
  }

  .pd__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  @media (hover: hover) {
    .pd__thumb:hover { opacity: 0.8; }
  }

  .pd__thumb[aria-pressed="true"] {
    opacity: 1;
    border-color: var(--color-brand);
  }

  /* ── Right: info panel ── */

  .pd__info {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: var(--space-10) var(--layout-gutter);
    gap: var(--space-5);
    min-height: 0;
  }

  .pd__summary,
  .pd__support {
    display: contents;
  }

  @keyframes title-settle {
    from { opacity: 0.84; }
    to   { opacity: 1; }
  }

  .pd__title {
    font-family: var(--font-heading-text);
    font-size: clamp(var(--font-size-3xl), 6vw, var(--font-size-display));
    font-weight: var(--font-weight-regular);
    line-height: var(--font-leading-tight);
    letter-spacing: var(--font-tracking-normal);
    color: var(--color-text-primary);
    margin: 0;
    animation: title-settle 900ms var(--ease-out-expo) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .pd__title { animation: none; }
  }

  .pd__price {
    font-family: var(--font-body-text);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--font-tracking-wide);
    color: var(--color-text-secondary);
    font-variant-numeric: tabular-nums;
  }

  .pd__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .pd__description {
    font-size: var(--font-size-base);
    line-height: var(--font-leading-relaxed);
    color: var(--color-text-primary);
    margin: 0;
  }

  /* ── CTA ── */

  .pd__buy {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 100%;
    max-width: 280px;
    min-height: var(--space-12);
    padding: 0 var(--space-8);
    background-color: var(--color-bg-statement);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    font-family: var(--font-body-text);
    font-size: var(--font-size-base);
    letter-spacing: var(--font-tracking-wider);
    text-transform: lowercase;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: background-color var(--transition-normal), border-color var(--transition-normal), transform var(--transition-fast);
  }

  .pd__buy::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-brand-subtle);
    border-radius: inherit;
    translate: 0 100%;
    transition: translate 360ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pd__buy:active {
    transform: translateY(var(--space-1));
  }

  .pd__buy-text {
    position: relative;
    z-index: 1;
  }

  @media (hover: hover) {
    .pd__buy:hover {
      border-color: var(--color-brand);
    }

    .pd__buy:hover::before { translate: 0 0; }
  }

  /* ── Tablet ── */

  @media (max-width: 1000px) {
    .pd {
      grid-template-columns: 1fr;
      height: auto;
    }

    .pd__stage {
      height: min(48svh, 460px);
      min-height: 320px;
    }

    .pd__info {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.85fr);
      align-items: start;
      column-gap: var(--layout-gutter);
      row-gap: var(--space-5);
      max-width: var(--layout-site-width);
      width: 100%;
      margin-inline: auto;
      padding-block: var(--space-8) var(--space-12);
    }

    .pd__summary,
    .pd__support {
      display: flex;
      flex-direction: column;
    }

    .pd__summary {
      grid-column: 1;
      grid-row: 1;
      gap: var(--space-5);
    }

    .pd__support {
      grid-column: 2;
      grid-row: 1;
      gap: var(--space-5);
    }

    .pd__title {
      font-size: var(--font-size-3xl);
    }

  }

  /* ── Mobile ── */

  @media (max-width: 760px) {
    .pd {
      grid-template-columns: 1fr;
      height: auto;
    }

    .pd__stage {
      height: min(58svh, 480px);
      min-height: 300px;
    }

    .pd__info {
      display: flex;
      padding: var(--space-8) var(--layout-gutter) var(--space-16);
      gap: var(--space-6);
    }

    .pd__summary,
    .pd__support {
      display: flex;
      flex-direction: column;
    }

    .pd__summary {
      gap: var(--space-4);
    }

    .pd__support {
      gap: var(--space-5);
    }

    .pd__title {
      font-size: var(--font-size-3xl);
      margin-top: 0;
    }

    .pd__price {
      font-size: var(--font-size-lg);
    }

    .pd__buy {
      width: 100%;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLElement>("[data-gallery]").forEach((gallery) => {
      const slides = Array.from(gallery.querySelectorAll<HTMLElement>("[data-slide]"));
      if (slides.length < 2) return;

      const thumbs = Array.from(gallery.querySelectorAll<HTMLButtonElement>("[data-thumb]"));
      let current = 0;
      let bounds = gallery.getBoundingClientRect();

      const show = (next: number) => {
        slides[current].setAttribute("aria-hidden", "true");
        thumbs[current]?.setAttribute("aria-pressed", "false");
        current = ((next % slides.length) + slides.length) % slides.length;
        slides[current].setAttribute("aria-hidden", "false");
        thumbs[current]?.setAttribute("aria-pressed", "true");
      };

      const isLeftSide = (clientX: number) => (clientX - bounds.left) < bounds.width / 2;
      const hasHover = window.matchMedia("(hover: hover)").matches;

      gallery.addEventListener("mouseenter", () => {
        bounds = gallery.getBoundingClientRect();
      });

      window.addEventListener("resize", () => {
        bounds = gallery.getBoundingClientRect();
      });

      gallery.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).closest("[data-thumb]")) return;
        show(isLeftSide(e.clientX) ? current - 1 : current + 1);
      });

      thumbs.forEach((btn) => {
        btn.addEventListener("click", () => show(Number(btn.dataset.thumb)));
      });

      if (hasHover) {
        gallery.addEventListener("mousemove", (e) => {
          if ((e.target as HTMLElement).closest("[data-thumb]")) return;
          gallery.classList.toggle("is-left", isLeftSide(e.clientX));

          const rx = (e.clientX - bounds.left) / bounds.width - 0.5;
          const ry = (e.clientY - bounds.top) / bounds.height - 0.5;
          gallery.style.setProperty("--parallax-x", `${rx * -6}px`);
          gallery.style.setProperty("--parallax-y", `${ry * -4}px`);
        });

        gallery.addEventListener("mouseleave", () => {
          gallery.style.removeProperty("--parallax-x");
          gallery.style.removeProperty("--parallax-y");
        });
      }

      gallery.addEventListener("keydown", (e) => {
        if (e.key === "ArrowLeft") {
          e.preventDefault();
          show(current - 1);
        } else if (e.key === "ArrowRight") {
          e.preventDefault();
          show(current + 1);
        } else if (e.key === "Home") {
          e.preventDefault();
          show(0);
        } else if (e.key === "End") {
          e.preventDefault();
          show(slides.length - 1);
        }
      });
    });
  });
</script>
