---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { getProductSlug } from "../config/site";

type Props = {
  items: CollectionEntry<"jewelry">[] | CollectionEntry<"knitting">[];
  section: "smycken" | "stickning";
  ariaLabel: string;
};

const { items, section, ariaLabel } = Astro.props;
const fmt = new Intl.NumberFormat("sv-SE").format;
const baseUrl = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/`;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;
---

<div class="listing">
  <section class="product-grid" aria-label={ariaLabel}>
    {items.map((entry, index) => {
      const productSlug = getProductSlug(entry.id);
      const href = withBase(`/${section}/${productSlug}`);
      return (
        <a class="product-card" href={href} aria-label={`Visa ${entry.data.title}`}>
          <figure class="product-card__figure">
            <div class="product-card__media" transition:name={`product-${productSlug}`}>
              <Image
                src={entry.data.images[0]}
                alt={entry.data.title}
                width={720}
                height={900}
                loading={index < 4 ? "eager" : "lazy"}
                fetchpriority={index === 0 ? "high" : "auto"}
              />
            </div>
            <figcaption class="product-card__caption">
              <div class="product-card__line">
                <h2 class="product-card__title" transition:name={`product-title-${productSlug}`} transition:animate="none">{entry.data.title}</h2>
                <span class="product-card__price">{fmt(entry.data.price)} kr</span>
              </div>
              {entry.data.description && (
                <p class="product-card__description">{entry.data.description}</p>
              )}
            </figcaption>
          </figure>
        </a>
      );
    })}
  </section>
</div>

<style>
  .listing {
    max-width: var(--layout-wide-width);
    margin: 0 auto;
    padding: var(--space-8) var(--layout-gutter) var(--space-24);
    box-sizing: border-box;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
    gap: clamp(var(--space-8), 5vw, var(--space-16)) clamp(var(--space-4), 2.2vw, var(--space-8));
    align-items: start;
  }

  .product-card {
    display: block;
    color: var(--color-text-primary);
  }

  .product-card__figure {
    margin: 0;
    display: grid;
    gap: var(--space-3);
  }

  .product-card__media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-bg-muted);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    position: relative;
    transition:
      background-color var(--transition-slow),
      border-color var(--transition-slow),
      transform var(--transition-slow);
  }

  .product-card__media::after {
    content: "";
    position: absolute;
    inset: var(--space-2);
    border: 1px solid color-mix(in oklch, var(--color-text-primary) 9%, transparent);
    opacity: 0.55;
    pointer-events: none;
    transition:
      opacity var(--transition-normal),
      transform var(--transition-slow);
  }

  .product-card__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition:
      filter var(--transition-slow),
      transform var(--transition-slow);
  }

  .product-card__caption {
    display: grid;
    gap: var(--space-2);
    padding-right: var(--space-2);
    transition: transform var(--transition-slow);
  }

  .product-card__line {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    align-items: baseline;
  }

  .product-card__title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-regular);
    line-height: var(--font-leading-snug);
    position: relative;
  }

  .product-card__title::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.12em;
    height: 1px;
    background: currentColor;
    opacity: 0;
    transform: scaleX(0.35);
    transform-origin: left;
    transition:
      opacity var(--transition-normal),
      transform var(--transition-slow);
  }

  .product-card__price {
    flex: 0 0 auto;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    letter-spacing: var(--font-tracking-wide);
    font-variant-numeric: tabular-nums;
    transition:
      color var(--transition-normal),
      opacity var(--transition-normal),
      transform var(--transition-normal);
  }

  .product-card__description {
    max-width: 34ch;
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: var(--font-leading-snug);
    color: var(--color-text-secondary);
    text-wrap: pretty;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition:
      color var(--transition-normal),
      transform var(--transition-slow);
  }

  @media (hover: hover) {
    .product-card:hover .product-card__media {
      background-color: var(--color-bg-surface);
      border-color: var(--color-border-default);
      transform: translateY(calc(var(--space-1) * -1));
    }

    .product-card:hover .product-card__media::after {
      opacity: 0.25;
      transform: scale(0.96);
    }

    .product-card:hover .product-card__media img {
      filter: contrast(1.02) saturate(0.95);
      transform: scale(1.035);
    }

    .product-card:hover .product-card__title::after {
      opacity: 0.55;
      transform: scaleX(1);
    }

    .product-card:hover .product-card__price,
    .product-card:hover .product-card__description {
      color: var(--color-text-primary);
    }
  }

  @media (min-width: 1320px) {
    .product-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (min-width: 860px) and (max-width: 1319px) {
    .product-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .listing {
      padding-top: var(--space-6);
      padding-bottom: var(--space-16);
    }

    .product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: var(--space-3);
      row-gap: var(--space-12);
    }

    .product-card__figure {
      gap: var(--space-2);
    }

    .product-card__line {
      display: grid;
      gap: var(--space-1);
    }

    .product-card__title {
      font-size: var(--font-size-base);
    }

    .product-card__price,
    .product-card__description {
      font-size: var(--font-size-xs);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-card__media,
    .product-card__media::after,
    .product-card__media img,
    .product-card__caption,
    .product-card__price,
    .product-card__description,
    .product-card__title::after {
      transition: none;
    }
  }
</style>
